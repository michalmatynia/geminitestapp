sh_binary(
    name = "weekly_quality_report",
    srcs = ["tools/bazel/node_script.sh"],
    args = ["scripts/quality/generate-weekly-report.mjs", "--strict", "--ci"],
    data = [
        ":weekly_quality_inputs",
        ":node_modules",
        ":package_metadata",
    ],
