{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": "../..",
    "paths": {
      "@kangur/contracts": ["./packages/kangur-contracts/src/index.ts"],
      "@kangur/platform": ["./packages/kangur-platform/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
