{
  "specVersion": "ai-paths.semantic-grammar.v1",
  "nodeType": "router",
  "title": "Router",
  "purpose": "Route payloads based on a condition.",
  "inputs": [
    "context",
    "bundle",
    "prompt",
    "result",
    "value",
    "valid",
    "errors"
  ],
  "outputs": [
    "context",
    "bundle",
    "prompt",
    "result",
    "value",
    "valid",
    "errors"
  ],
  "configFields": [
    {
      "path": "router.mode",
      "description": "valid routes on valid/errors; value routes on a value input.",
      "defaultValue": "value"
    },
    {
      "path": "router.matchMode",
      "description": "truthy/falsy/equals/contains",
      "defaultValue": "truthy"
    },
    {
      "path": "router.compareTo",
      "description": "Used by equals/contains modes.",
      "defaultValue": "\"\""
    },
    {
      "path": "runtime.cache.mode",
      "description": "Node output caching. auto = reuse when safe, force = always reuse, disabled = recompute each run.",
      "defaultValue": "auto"
    },
    {
      "path": "runtime.waitForInputs",
      "description": "If true, wait until all connected input ports have values before executing the node.",
      "defaultValue": "false"
    }
  ],
  "notes": [],
  "semanticNodeExample": {
    "id": "node_router",
    "type": "router",
    "title": "Router",
    "description": "Route payloads based on a condition.",
    "position": {
      "x": 100,
      "y": 100
    },
    "inputs": [
      "context",
      "bundle",
      "prompt",
      "result",
      "value",
      "valid",
      "errors"
    ],
    "outputs": [
      "context",
      "bundle",
      "prompt",
      "result",
      "value",
      "valid",
      "errors"
    ],
    "data": {},
    "connections": {
      "incoming": [],
      "outgoing": []
    }
  }
}
