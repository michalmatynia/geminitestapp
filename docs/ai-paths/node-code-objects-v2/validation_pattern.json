  "runtimeSemantics": {
    "executionKind": "synchronous",
    "waitForResultSupported": false,
    "wireActivationRules": {
      "processing": "When node is processing, show node pulse only. Do not animate outgoing edges until an output port value is produced.",
      "waiting": "When node is waiting for external response, keep both consumed incoming and future outgoing edges inactive.",
      "completed": "Animate only edges carrying newly emitted outputs.",
      "errored": "Animate only explicit error-route outputs (if connected)."
    }
  },
