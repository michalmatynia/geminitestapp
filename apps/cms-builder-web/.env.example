# Local-only CMS Builder MongoDB. Copy to .env.local for local development.
CMS_BUILDER_MONGO_ISOLATED="true"
MONGODB_LOCAL_URI="mongodb://127.0.0.1:27019/cms_builder_local"
MONGODB_LOCAL_DB="cms_builder_local"
MONGODB_CLOUD_URI="mongodb+srv://cluster.example/?retryWrites=true&w=majority&authSource=admin"
MONGODB_CLOUD_DB="cms_builder_db"
MONGODB_ACTIVE_SOURCE_DEFAULT="local"
APP_DB_PROVIDER="mongodb"
AUTH_DB_PROVIDER="mongodb"
