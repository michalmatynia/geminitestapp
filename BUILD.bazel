sh_binary(
    name = "accessibility_smoke",
    srcs = ["tools/bazel/node_script.sh"],
    args = ["scripts/testing/run-accessibility-smoke-tests.mjs", "--strict", "--ci"],
    data = [
        ":testing_gate_inputs",
        ":node_modules",
