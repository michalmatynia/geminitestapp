        "path": "runtime.cache.mode",
        "description": "Node output caching. auto = reuse when safe, force = always reuse, disabled = recompute each run.",
        "defaultValue": "auto"
      },
      {
        "path": "runtime.cache.scope",
        "description": "Cache key scope. run = isolate each run, activation = isolate by trigger/entity context, session = reuse across session.",
