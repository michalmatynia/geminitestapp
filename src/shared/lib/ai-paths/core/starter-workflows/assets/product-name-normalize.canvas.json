    {
      "id": "node-prompt-name-normalize",
      "type": "prompt",
      "title": "Prompt",
      "description": "Build the semantic normalization prompt for the product name.",
      "position": {
        "x": 900,
        "y": 320
      },
      "inputs": ["bundle", "images"],
      "outputs": ["prompt", "images"],
      "config": {
        "prompt": {
          "template": "You normalize English ecommerce product names.\\nUse only evidence from the current product fields, images, and the Context Registry bundle supplied in the system context.\\nThe Context Registry contains the authoritative leaf-category vocabulary for the active catalog selection. Choose category ONLY from that leaf-category list. Never use parent categories and never invent category names that are not present in that list.\\n\\nCurrent English title: \\\"{{title}}\\\"\\nCurrent English description: \\\"{{content_en}}\\\"\\nProduct JSON: {{bundle}}\\n\\nReturn ONLY valid JSON object with this exact schema:\\n{\"title\":\"\",\"size\":\"\",\"material\":\"\",\"category\":\"\",\"theme\":\"\",\"normalizedName\":\"\",\"confidence\":0.0}\\n\\nRules:\\n1. normalizedName MUST exactly equal \\\"<title> | <size> | <material> | <category> | <theme>\\\".\\n2. Every field except confidence must be a non-empty English string.\\n3. category MUST exactly match one leaf category name from the Context Registry bundle.\\n4. Use concise normalized values with no markdown and no extra commentary.\\n5. If size, material, or theme cannot be inferred confidently, use \\\"Unknown\\\" for that field.\\n6. confidence must be a number between 0 and 1.\\n7. Output JSON only."
        }
      },
