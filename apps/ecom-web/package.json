{
  "name": "@app/ecom-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev --webpack --port 3300",
    "build": "next build --webpack && node scripts/prepare-vercel-output.mjs",
    "start": "next start --port 3300",
    "test": "vitest run --config vitest.config.mjs",
    "lint": "cd ../.. && cross-env NODE_OPTIONS=--max-old-space-size=8192 eslint \"apps/ecom-web/src/**/*.{ts,tsx,js,jsx}\" --max-warnings=0 --no-error-on-unmatched-pattern",
    "lint:fix": "cd ../.. && cross-env NODE_OPTIONS=--max-old-space-size=8192 eslint \"apps/ecom-web/src/**/*.{ts,tsx,js,jsx}\" --max-warnings=0 --fix --no-error-on-unmatched-pattern",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit --pretty false",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false",
    "cms:locales:backfill": "tsx scripts/backfill-cms-locales.ts",
    "cms:locales:backfill:apply": "tsx scripts/backfill-cms-locales.ts --apply",
    "mongo:ecom-products:up": "node ../../scripts/db/local-ecom-products-mongo.mjs up",
    "mongo:ecom-products:down": "node ../../scripts/db/local-ecom-products-mongo.mjs down",
    "mongo:ecom-products:status": "node ../../scripts/db/local-ecom-products-mongo.mjs status",
    "mongo:products:up": "cd ../.. && npm run mongo:products:up",
    "mongo:products:down": "cd ../.. && npm run mongo:products:down",
    "mongo:products:status": "cd ../.. && npm run mongo:products:status",
    "mongo:ecom:up": "MONGODB_PORT=27021 MONGODB_DATA_DIR=../../../database/ecom-mongo-data MONGODB_RUNTIME_DIR=../../../database/ecom-mongo-runtime node ../../scripts/db/local-mongo.mjs up",
    "mongo:ecom:down": "MONGODB_PORT=27021 MONGODB_DATA_DIR=../../../database/ecom-mongo-data MONGODB_RUNTIME_DIR=../../../database/ecom-mongo-runtime node ../../scripts/db/local-mongo.mjs down",
    "mongo:ecom:status": "MONGODB_PORT=27021 MONGODB_DATA_DIR=../../../database/ecom-mongo-data MONGODB_RUNTIME_DIR=../../../database/ecom-mongo-runtime node ../../scripts/db/local-mongo.mjs status"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "bcryptjs": "^3.0.3",
    "gsap": "^3.15.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "mongodb": "^7.2.0",
    "next": "16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.12.3",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "postcss": "^8.5.14",
    "@tailwindcss/postcss": "^4.3.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3"
  },
  "browserslist": [
    "chrome >= 100",
    "firefox >= 100",
    "safari >= 15.4",
    "edge >= 100",
    "not dead"
  ]
}
