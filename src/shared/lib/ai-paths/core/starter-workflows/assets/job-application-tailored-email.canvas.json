          },
          "upsert": true,
          "updatePayloadMode": "custom",
          "updateTemplate": "{\"$setOnInsert\":{\"_id\":\"ai-job-application-{{context.entityJson.applicationContext.personContext.selectedPersonId}}-{{context.entityJson.applicationContext.organizationContext.selectedOrganizationId}}-{{context.entityJson.applicationContext.jobContext.selectedJobListingId}}-{{context.entityJson.applicationContext.platformContext.integrationSlug}}\",\"id\":\"ai-job-application-{{context.entityJson.applicationContext.personContext.selectedPersonId}}-{{context.entityJson.applicationContext.organizationContext.selectedOrganizationId}}-{{context.entityJson.applicationContext.jobContext.selectedJobListingId}}-{{context.entityJson.applicationContext.platformContext.integrationSlug}}\",\"status\":\"draft\",\"personId\":\"{{context.entityJson.applicationContext.personContext.selectedPersonId}}\",\"organizationId\":\"{{context.entityJson.applicationContext.organizationContext.selectedOrganizationId}}\",\"jobListingId\":\"{{context.entityJson.applicationContext.jobContext.selectedJobListingId}}\",\"integrationSlug\":\"{{context.entityJson.applicationContext.platformContext.integrationSlug}}\",\"canonicalApplicationKey\":\"{{context.entityJson.applicationContext.personContext.selectedPersonId}}::{{context.entityJson.applicationContext.organizationContext.selectedOrganizationId}}::{{context.entityJson.applicationContext.jobContext.selectedJobListingId}}::{{context.entityJson.applicationContext.platformContext.integrationSlug}}\",\"createdAt\":\"{{context.timestamp}}\"},\"$set\":{\"personName\":\"{{context.entityJson.applicationContext.personContext.person.fullName}}\",\"organizationName\":\"{{context.entityJson.applicationContext.organizationContext.organization.name}}\",\"jobTitle\":\"{{context.entityJson.applicationContext.jobContext.listing.title}}\",\"integrationId\":\"{{context.entityJson.applicationContext.platformContext.integrationId}}\",\"integrationSlug\":\"{{context.entityJson.applicationContext.platformContext.integrationSlug}}\",\"connectionId\":\"{{context.entityJson.applicationContext.platformContext.connectionId}}\",\"canonicalApplicationKey\":\"{{context.entityJson.applicationContext.personContext.selectedPersonId}}::{{context.entityJson.applicationContext.organizationContext.selectedOrganizationId}}::{{context.entityJson.applicationContext.jobContext.selectedJobListingId}}::{{context.entityJson.applicationContext.platformContext.integrationSlug}}\",\"source\":\"ai-path-job-application-tailored-email\",\"sourceEntityId\":\"{{context.entityId}}\",\"sourceApplicationContext\":{\"version\":{{context.entityJson.applicationContext.version}},\"personId\":\"{{context.entityJson.applicationContext.personContext.selectedPersonId}}\",\"organizationId\":\"{{context.entityJson.applicationContext.organizationContext.selectedOrganizationId}}\",\"jobListingId\":\"{{context.entityJson.applicationContext.jobContext.selectedJobListingId}}\",\"integrationSlug\":\"{{context.entityJson.applicationContext.platformContext.integrationSlug}}\",\"sourceEntityId\":\"{{context.entityId}}\"},\"updatedAt\":\"{{context.timestamp}}\",\"activeArtifacts.applicationEmailVersionId\":\"ai-job-application-email-{{context.entityId}}-{{context.timestamp}}\",\"applicationEmail\":{{value.applicationEmail}}},\"$inc\":{\"artifactVersionCounters.applicationEmail\":1},\"$push\":{\"artifactVersions.applicationEmail\":{\"id\":\"ai-job-application-email-{{context.entityId}}-{{context.timestamp}}\",\"kind\":\"application_email\",\"linkedRecordId\":null,\"payload\":{{value.applicationEmail}},\"applicationNotes\":{{value.applicationNotes}},\"missingInformation\":{{value.missingInformation}},\"confidence\":{{value.confidence}},\"sourceRunId\":\"{{context.entityId}}\",\"createdAt\":\"{{context.timestamp}}\"}}}"
        },
