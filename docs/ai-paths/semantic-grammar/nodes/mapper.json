{
  "specVersion": "ai-paths.semantic-grammar.v1",
  "nodeDocVersion": "2026-02-20.v1",
  "nodeType": "mapper",
  "title": "JSON Mapper",
  "purpose": "Map context to custom outputs.",
  "inputs": ["context", "result", "bundle", "value"],
  "outputs": ["value", "result"],
  "configFields": [
    {
      "path": "mapper.outputs",
      "description": "Which output ports the mapper should expose (the ports must exist on the node).",
      "defaultValue": "[\"value\"]"
    },
    {
      "path": "mapper.mappings",
      "description": "Map output port name -> JSON path (relative to context).",
      "defaultValue": "{}"
    },
    {
      "path": "runtime.cache.mode",
      "description": "Node output caching. auto = reuse when safe, force = always reuse, disabled = recompute each run.",
      "defaultValue": "auto"
    },
    {
      "path": "runtime.waitForInputs",
      "description": "If true, wait until all connected input ports have values before executing the node.",
      "defaultValue": "false"
    }
  ],
