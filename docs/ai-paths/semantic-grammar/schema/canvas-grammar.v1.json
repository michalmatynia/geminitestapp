{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.docs/ai-paths/semantic-grammar/canvas-grammar.v1.json",
  "title": "AI-Paths Semantic Grammar v1",
  "description": "Portable JSON grammar for AI-Paths canvas and subgraph exports.",
  "oneOf": [
    { "$ref": "#/$defs/CanvasSemanticDocument" },
    { "$ref": "#/$defs/SubgraphSemanticDocument" }
  ],
  "$defs": {
    "SemanticPortBinding": {
      "type": "object",
      "properties": {
        "edgeId": { "type": "string" },
        "fromNodeId": { "type": "string" },
        "fromPort": { "type": ["string", "null"] },
        "toNodeId": { "type": "string" },
        "toPort": { "type": ["string", "null"] }
      },
      "required": ["fromNodeId", "toNodeId"],
      "additionalProperties": false
    },
    "SemanticNodeConnections": {
      "type": "object",
      "properties": {
        "incoming": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticPortBinding" }
        },
        "outgoing": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticPortBinding" }
        }
      },
      "required": ["incoming", "outgoing"],
      "additionalProperties": false
    },
    "SemanticNode": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "position": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          },
          "required": ["x", "y"],
          "additionalProperties": false
        },
        "inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "config": { "type": "object", "additionalProperties": true },
        "data": { "type": "object", "additionalProperties": true },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": ["string", "null"] },
        "connections": { "$ref": "#/$defs/SemanticNodeConnections" },
        "extensions": { "type": "object", "additionalProperties": true }
      },
      "required": ["id", "type", "title", "description", "position", "inputs", "outputs"],
      "additionalProperties": false
    },
    "SemanticEdge": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fromNodeId": { "type": "string" },
        "toNodeId": { "type": "string" },
        "fromPort": { "type": ["string", "null"] },
        "toPort": { "type": ["string", "null"] },
        "label": { "type": ["string", "null"] },
        "type": { "type": "string" },
        "data": { "type": "object", "additionalProperties": true },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": ["string", "null"] }
      },
      "required": ["id", "fromNodeId", "toNodeId"],
      "additionalProperties": false
    },
    "SemanticPathDescriptor": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "number" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "trigger": { "type": "string" },
        "updatedAt": { "type": "string" },
        "executionMode": { "type": "string" },
        "flowIntensity": { "type": "string" },
        "runMode": { "type": "string" },
        "strictFlowMode": { "type": "boolean" },
        "isLocked": { "type": "boolean" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "version", "name", "description", "trigger", "updatedAt"],
      "additionalProperties": false
    },
    "SemanticExecutionDescriptor": {
      "type": "object",
      "properties": {
        "parserSamples": { "type": "object", "additionalProperties": true },
        "updaterSamples": { "type": "object", "additionalProperties": true },
        "runtimeState": {},
        "lastRunAt": { "type": ["string", "null"] },
        "runCount": { "type": "number" }
      },
      "additionalProperties": false
    },
    "SemanticProvenance": {
      "type": "object",
      "properties": {
        "source": { "const": "ai-paths" },
        "exportedAt": { "type": "string" },
        "pathId": { "type": "string" },
        "exporterVersion": { "type": "string" },
        "workspace": { "type": "string" }
      },
      "required": ["source", "exportedAt"],
      "additionalProperties": false
    },
    "CanvasSemanticDocument": {
      "type": "object",
      "properties": {
        "specVersion": { "const": "ai-paths.semantic-grammar.v1" },
        "kind": { "const": "canvas" },
        "path": { "$ref": "#/$defs/SemanticPathDescriptor" },
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticNode" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticEdge" }
        },
        "execution": { "$ref": "#/$defs/SemanticExecutionDescriptor" },
        "validation": { "type": "object", "additionalProperties": true },
        "provenance": { "$ref": "#/$defs/SemanticProvenance" },
        "extensions": { "type": "object", "additionalProperties": true }
      },
      "required": ["specVersion", "kind", "path", "nodes", "edges"],
      "additionalProperties": false
    },
    "SemanticBoundary": {
      "type": "object",
      "properties": {
        "incoming": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticPortBinding" }
        },
        "outgoing": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticPortBinding" }
        }
      },
      "required": ["incoming", "outgoing"],
      "additionalProperties": false
    },
    "SubgraphSemanticDocument": {
      "type": "object",
      "properties": {
        "specVersion": { "const": "ai-paths.semantic-grammar.v1" },
        "kind": { "const": "subgraph" },
        "pathId": { "type": "string" },
        "selectedNodeIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticNode" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/SemanticEdge" }
        },
        "boundary": { "$ref": "#/$defs/SemanticBoundary" },
        "provenance": { "$ref": "#/$defs/SemanticProvenance" },
        "extensions": { "type": "object", "additionalProperties": true }
      },
      "required": ["specVersion", "kind", "selectedNodeIds", "nodes", "edges", "boundary"],
      "additionalProperties": false
    }
  }
}
