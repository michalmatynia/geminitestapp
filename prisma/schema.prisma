generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                  String                      @id @default(cuid())
  sku                 String?                     @unique
  name_en             String?
  name_pl             String?
  name_de             String?
  description_en      String?
  description_pl      String?
  description_de      String?
  supplierName        String?
  supplierLink        String?
  priceComment        String?
  stock               Int?
  price               Int?
  sizeLength          Int?
  sizeWidth           Int?
  weight              Int?
  length              Int?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  asin                String?
  baseProductId       String?
  defaultPriceGroupId String?
  ean                 String?
  gtin                String?
  imageBase64s        String[]                    @default([])
  imageLinks          String[]                    @default([])
  noteIds             String[]                    @default([])
  parameters          Json                        @default("[]")
  defaultPriceGroup   PriceGroup?                 @relation(fields: [defaultPriceGroupId], references: [id])
  catalogs            ProductCatalog[]
  categories          ProductCategoryAssignment?
  images              ProductImage[]
  listings            ProductListing[]
  producers           ProductProducerAssignment[]
  tags                ProductTagAssignment[]
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemLog {
  id         String   @id @default(cuid())
  level      String   @default("error")
  message    String
  category   String?
  source     String?
  context    Json?
  stack      String?
  path       String?
  method     String?
  statusCode Int?
  requestId  String?
  userId     String?
  createdAt  DateTime @default(now())

  @@index([level])
  @@index([category])
  @@index([createdAt])
}

model ActivityLog {
  id          String   @id @default(cuid())
  type        String
  description String
  userId      String?
  entityId    String?
  entityType  String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([entityId, entityType])
  @@index([createdAt])
}

model FileUploadEvent {
  id           String   @id @default(cuid())
  status       String
  category     String?
  projectId    String?
  folder       String?
  filename     String?
  filepath     String?
  mimetype     String?
  size         Int?
  source       String?
  errorMessage String?
  requestId    String?
  userId       String?
  meta         Json?
  createdAt    DateTime @default(now())

  @@index([status])
  @@index([category])
  @@index([projectId])
  @@index([createdAt])
}

model ChatbotSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  settings  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ImageFile {
  id                         String            @id @default(cuid())
  filename                   String
  filepath                   String
  mimetype                   String
  size                       Int
  width                      Int?
  height                     Int?
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  tags                       String[]          @default([])
  imageStudioSlotImages      ImageStudioSlot[] @relation("ImageStudioSlotImage")
  imageStudioSlotScreenshots ImageStudioSlot[] @relation("ImageStudioSlotScreenshot")
  products                   ProductImage[]
}

model Currency {
  id          String            @id @default(cuid())
  code        CurrencyCode      @unique
  name        String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  symbol      String?
  countries   CountryCurrency[]
  priceGroups PriceGroup[]
}

model Country {
  id         String            @id @default(cuid())
  name       String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  code       CountryCode       @unique
  currencies CountryCurrency[]
  languages  LanguageCountry[]
}

model Integration {
  id          String                 @id @default(cuid())
  name        String
  slug        String                 @unique
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  connections IntegrationConnection?
  listings    ProductListing[]
}

model IntegrationConnection {
  id                              String           @id @default(cuid())
  integrationId                   String           @unique
  name                            String
  username                        String
  password                        String
  createdAt                       DateTime         @default(now())
  updatedAt                       DateTime         @updatedAt
  playwrightStorageState          String?
  playwrightStorageStateUpdatedAt DateTime?
  playwrightHeadless              Boolean          @default(true)
  playwrightNavigationTimeout     Int              @default(30000)
  playwrightSlowMo                Int              @default(50)
  playwrightTimeout               Int              @default(15000)
  playwrightClickDelayMax         Int              @default(120)
  playwrightClickDelayMin         Int              @default(30)
  playwrightHumanizeMouse         Boolean          @default(false)
  playwrightMouseJitter           Int              @default(6)
  playwrightActionDelayMax        Int              @default(900)
  playwrightActionDelayMin        Int              @default(200)
  playwrightDeviceName            String?
  playwrightEmulateDevice         Boolean          @default(false)
  playwrightInputDelayMax         Int              @default(120)
  playwrightInputDelayMin         Int              @default(20)
  playwrightProxyEnabled          Boolean          @default(false)
  playwrightProxyPassword         String?
  playwrightProxyServer           String?
  playwrightProxyUsername         String?
  allegroAccessToken              String?
  allegroExpiresAt                DateTime?
  allegroRefreshToken             String?
  allegroScope                    String?
  allegroTokenType                String?
  allegroTokenUpdatedAt           DateTime?
  allegroUseSandbox               Boolean          @default(false)
  baseApiToken                    String?
  baseLastInventoryId             String?
  baseTokenUpdatedAt              DateTime?
  integration                     Integration      @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  listings                        ProductListing[]
}

model ProductListing {
  id                String                @id @default(cuid())
  productId         String
  integrationId     String
  connectionId      String
  externalListingId String?
  inventoryId       String?
  status            String                @default("pending")
  listedAt          DateTime?
  exportHistory     Json?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  connection        IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  integration       Integration           @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  product           Product               @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, connectionId])
}

model Language {
  id                 String            @id @default(cuid())
  code               String            @unique
  name               String
  nativeName         String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  defaultForCatalogs Catalog[]         @relation("CatalogDefaultLanguage")
  catalogs           CatalogLanguage[]
  countries          LanguageCountry[]
}

model PriceGroup {
  id              String       @id @default(cuid())
  groupId         String       @unique
  isDefault       Boolean      @default(false)
  name            String
  description     String?
  currencyId      String
  type            String
  basePriceField  String
  sourceGroupId   String?
  priceMultiplier Float        @default(1)
  addToPrice      Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  currency        Currency     @relation(fields: [currencyId], references: [id])
  sourceGroup     PriceGroup?  @relation("PriceGroupDependency", fields: [sourceGroupId], references: [id])
  dependentGroups PriceGroup[] @relation("PriceGroupDependency")
  products        Product[]
}

model ProductImage {
  productId   String
  imageFileId String
  assignedAt  DateTime  @default(now())
  imageFile   ImageFile @relation(fields: [imageFileId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, imageFileId])
}

model Catalog {
  id                  String             @id @default(cuid())
  name                String
  description         String?
  isDefault           Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  defaultLanguageId   String?
  defaultPriceGroupId String?
  priceGroupIds       String[]           @default([])
  defaultLanguage     Language?          @relation("CatalogDefaultLanguage", fields: [defaultLanguageId], references: [id])
  languages           CatalogLanguage[]
  products            ProductCatalog[]
  categories          ProductCategory[]
  parameters          ProductParameter[]
  tags                ProductTag[]
}

model ProductParameter {
  id        String   @id @default(cuid())
  catalogId String
  name_en   String
  name_pl   String?
  name_de   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  catalog   Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@unique([catalogId, name_en])
  @@index([catalogId])
}

model ProductCatalog {
  productId  String
  catalogId  String
  assignedAt DateTime @default(now())
  catalog    Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, catalogId])
}

model ChatbotAgentRun {
  id                        String                 @id @default(cuid())
  prompt                    String
  model                     String?
  tools                     String[]               @default([])
  searchProvider            String?
  agentBrowser              String?
  runHeadless               Boolean                @default(true)
  status                    AgentRunStatus         @default(queued)
  logLines                  String[]               @default([])
  requiresHumanIntervention Boolean                @default(false)
  errorMessage              String?
  memoryKey                 String?
  recordingPath             String?
  planState                 Json?
  activeStepId              String?
  checkpointedAt            DateTime?
  startedAt                 DateTime?
  finishedAt                DateTime?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  auditLogs                 AgentAuditLog[]
  browserLogs               AgentBrowserLog[]
  browserSnapshots          AgentBrowserSnapshot[]
  longTermMemory            AgentLongTermMemory[]
  memoryItems               AgentMemoryItem[]
}

model AgentMemoryItem {
  id        String           @id @default(cuid())
  runId     String?
  scope     AgentMemoryScope @default(session)
  content   String
  metadata  Json?
  createdAt DateTime         @default(now())
  run       ChatbotAgentRun? @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model AgentLongTermMemory {
  id             String           @id @default(cuid())
  memoryKey      String
  runId          String?
  scope          AgentMemoryScope @default(longterm)
  content        String
  summary        String?
  tags           String[]         @default([])
  metadata       Json?
  importance     Int?
  lastAccessedAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  run            ChatbotAgentRun? @relation(fields: [runId], references: [id])

  @@index([memoryKey])
  @@index([runId])
  @@index([updatedAt])
}

model AgentAuditLog {
  id        String           @id @default(cuid())
  runId     String?
  level     AgentAuditLevel  @default(info)
  message   String
  metadata  Json?
  createdAt DateTime         @default(now())
  run       ChatbotAgentRun? @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model AgentBrowserSnapshot {
  id             String          @id @default(cuid())
  runId          String
  url            String
  title          String?
  domHtml        String
  domText        String
  screenshotData String?
  screenshotPath String?
  stepId         String?
  mouseX         Int?
  mouseY         Int?
  viewportWidth  Int?
  viewportHeight Int?
  createdAt      DateTime        @default(now())
  run            ChatbotAgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model AgentBrowserLog {
  id        String          @id @default(cuid())
  runId     String
  stepId    String?
  level     String          @default("info")
  message   String
  metadata  Json?
  createdAt DateTime        @default(now())
  run       ChatbotAgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model ChatbotSession {
  id        String           @id @default(cuid())
  title     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  jobs      ChatbotJob[]
  messages  ChatbotMessage[]
}

model ChatbotMessage {
  id        String         @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime       @default(now())
  session   ChatbotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model ChatbotJob {
  id           String           @id @default(cuid())
  sessionId    String
  status       ChatbotJobStatus @default(pending)
  model        String?
  payload      Json
  resultText   String?
  errorMessage String?
  createdAt    DateTime         @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
  session      ChatbotSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model CatalogLanguage {
  catalogId  String
  languageId String
  assignedAt DateTime @default(now())
  position   Int      @default(0)
  catalog    Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@id([catalogId, languageId])
}

model LanguageCountry {
  languageId String
  countryId  String
  assignedAt DateTime @default(now())
  country    Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@id([languageId, countryId])
}

model CountryCurrency {
  countryId  String
  currencyId String
  assignedAt DateTime @default(now())
  country    Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  currency   Currency @relation(fields: [currencyId], references: [id], onDelete: Cascade)

  @@id([countryId, currencyId])
}

model Slug {
  id        String          @id @default(cuid())
  slug      String          @unique
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  domains   CmsDomainSlug[]
  pages     PageSlug[]
}

model CmsTheme {
  id         String   @id @default(cuid())
  name       String   @unique
  colors     Json
  typography Json
  spacing    Json
  customCss  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  pages      Page[]
}

model Page {
  id             String          @id @default(cuid())
  name           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  publishedAt    DateTime?
  robotsMeta     String?         @default("index,follow")
  seoCanonical   String?
  seoDescription String?
  seoOgImage     String?
  seoTitle       String?
  showMenu       Boolean         @default(true)
  status         String          @default("draft")
  themeId        String?
  theme          CmsTheme?       @relation(fields: [themeId], references: [id])
  components     PageComponent[]
  slugs          PageSlug[]
}

model PageSlug {
  pageId     String
  slugId     String
  assignedAt DateTime @default(now())
  page       Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  slug       Slug     @relation(fields: [slugId], references: [id], onDelete: Cascade)

  @@id([pageId, slugId])
}

model CmsDomain {
  id        String          @id @default(cuid())
  domain    String
  aliasOf   String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  slugs     CmsDomainSlug[]
}

model CmsDomainSlug {
  domainId   String
  slugId     String
  assignedAt DateTime  @default(now())
  isDefault  Boolean   @default(false)
  updatedAt  DateTime  @updatedAt
  domain     CmsDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  slug       Slug      @relation(fields: [slugId], references: [id], onDelete: Cascade)

  @@id([domainId, slugId])
}

model PageComponent {
  id        String   @id @default(cuid())
  type      String
  order     Int
  content   Json
  pageId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model Note {
  id            String         @id @default(cuid())
  title         String
  content       String
  color         String?        @default("#ffffff")
  isPinned      Boolean        @default(false)
  isArchived    Boolean        @default(false)
  isFavorite    Boolean        @default(false)
  notebookId    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  editorType    String         @default("markdown")
  notebook      Notebook?      @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  categories    NoteCategory[]
  files         NoteFile[]
  relationsFrom NoteRelation[] @relation("NoteRelationsFrom")
  relationsTo   NoteRelation[] @relation("NoteRelationsTo")
  tags          NoteTag[]
}

model NoteFile {
  id        String   @id @default(cuid())
  noteId    String
  slotIndex Int
  filename  String
  filepath  String
  mimetype  String
  size      Int
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, slotIndex])
}

model Theme {
  id                         String     @id @default(cuid())
  name                       String
  notebookId                 String?
  textColor                  String     @default("#e5e7eb")
  backgroundColor            String     @default("#111827")
  markdownHeadingColor       String     @default("#ffffff")
  markdownLinkColor          String     @default("#60a5fa")
  markdownCodeBackground     String     @default("#1f2937")
  markdownCodeText           String     @default("#e5e7eb")
  relatedNoteBorderWidth     Int        @default(1)
  relatedNoteBorderColor     String     @default("#374151")
  relatedNoteBackgroundColor String     @default("#1f2937")
  relatedNoteTextColor       String     @default("#e5e7eb")
  createdAt                  DateTime   @default(now())
  updatedAt                  DateTime   @updatedAt
  categories                 Category[]
  notebooksAsDefault         Notebook[] @relation("DefaultTheme")
  notebook                   Notebook?  @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@unique([notebookId, name])
}

model Tag {
  id         String    @id @default(cuid())
  name       String
  color      String?   @default("#3b82f6")
  notebookId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  notes      NoteTag[]
  notebook   Notebook? @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@unique([notebookId, name])
}

model Category {
  id          String         @id @default(cuid())
  name        String
  description String?
  color       String?        @default("#10b981")
  parentId    String?
  themeId     String?
  notebookId  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  sortIndex   Int            @default(0)
  notebook    Notebook?      @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  parent      Category?      @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[]     @relation("CategoryHierarchy")
  theme       Theme?         @relation(fields: [themeId], references: [id])
  notes       NoteCategory[]

  @@unique([notebookId, name])
}

model Notebook {
  id             String     @id @default(cuid())
  name           String     @unique
  color          String?    @default("#3b82f6")
  defaultThemeId String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  categories     Category[]
  notes          Note[]
  defaultTheme   Theme?     @relation("DefaultTheme", fields: [defaultThemeId], references: [id])
  tags           Tag[]
  themes         Theme[]
}

model NoteTag {
  noteId     String
  tagId      String
  assignedAt DateTime @default(now())
  note       Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}

model NoteCategory {
  noteId     String
  categoryId String
  assignedAt DateTime @default(now())
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  note       Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@id([noteId, categoryId])
}

model NoteRelation {
  sourceNoteId String
  targetNoteId String
  assignedAt   DateTime @default(now())
  sourceNote   Note     @relation("NoteRelationsFrom", fields: [sourceNoteId], references: [id], onDelete: Cascade)
  targetNote   Note     @relation("NoteRelationsTo", fields: [targetNoteId], references: [id], onDelete: Cascade)

  @@id([sourceNoteId, targetNoteId])
}

model ProductCategory {
  id          String                      @id @default(cuid())
  name        String
  description String?
  color       String?                     @default("#10b981")
  parentId    String?
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  catalogId   String
  mappings    CategoryMapping[]
  catalog     Catalog                     @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  parent      ProductCategory?            @relation("ProductCategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    ProductCategory[]           @relation("ProductCategoryHierarchy")
  products    ProductCategoryAssignment[]

  @@unique([catalogId, parentId, name])
}

model ProductCategoryAssignment {
  productId  String          @unique
  categoryId String
  assignedAt DateTime        @default(now())
  category   ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model ProductTag {
  id        String                 @id @default(cuid())
  name      String
  color     String?
  catalogId String
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  catalog   Catalog                @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  products  ProductTagAssignment[]

  @@unique([catalogId, name])
}

model ProductTagAssignment {
  productId  String
  tagId      String
  assignedAt DateTime   @default(now())
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag        ProductTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

model Producer {
  id        String                      @id @default(cuid())
  name      String                      @unique
  website   String?
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt
  products  ProductProducerAssignment[]
}

model ProductProducerAssignment {
  productId  String
  producerId String
  assignedAt DateTime @default(now())
  producer   Producer @relation(fields: [producerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, producerId])
}

model User {
  id              String               @id @default(cuid())
  name            String?
  email           String?              @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  accounts        Account[]
  securityProfile AuthSecurityProfile?
  sessions        Session[]
  preferences     UserPreferences?
}

model AuthSecurityProfile {
  id            String    @id @default(cuid())
  userId        String    @unique
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?
  recoveryCodes String[]  @default([])
  allowedIps    String[]  @default([])
  disabledAt    DateTime?
  bannedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuthLoginChallenge {
  id        String   @id @default(cuid())
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuthSecurityAttempt {
  id        String   @id @default(cuid())
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserPreferences {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  productListNameLocale      String?
  productListCatalogFilter   String?
  productListCurrencyCode    String?
  productListPageSize        Int?
  productListThumbnailSource String?
  aiPathsActivePathId        String?
  aiPathsExpandedGroups      String[] @default([])
  aiPathsPaletteCollapsed    Boolean? @default(false)
  aiPathsPathIndex           Json?
  aiPathsPathConfigs         Json?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AiConfiguration {
  id                         String   @id @default(cuid())
  type                       String?
  descriptionGenerationModel String?
  generationInputPrompt      String?
  generationOutputEnabled    Boolean  @default(false)
  generationOutputPrompt     String?
  imageAnalysisModel         String?
  visionInputPrompt          String?
  visionOutputEnabled        Boolean  @default(false)
  visionOutputPrompt         String?
  testProductId              String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model ProductAiJob {
  id           String             @id @default(cuid())
  productId    String
  status       ProductAiJobStatus @default(pending)
  type         String             @default("description_generation")
  payload      Json
  result       Json?
  errorMessage String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  startedAt    DateTime?
  finishedAt   DateTime?

  @@index([productId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model AiPathRun {
  id             String           @id @default(cuid())
  userId         String?
  pathId         String
  pathName       String?
  status         AiPathRunStatus  @default(queued)
  triggerEvent   String?
  triggerNodeId  String?
  triggerContext Json?
  graph          Json?
  runtimeState   Json?
  meta           Json?
  entityId       String?
  entityType     String?
  errorMessage   String?
  retryCount     Int              @default(0)
  maxAttempts    Int              @default(3)
  nextRetryAt    DateTime?
  deadLetteredAt DateTime?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  events         AiPathRunEvent[]
  nodes          AiPathRunNode[]

  @@index([pathId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([nextRetryAt])
}

model AiPathRunNode {
  id           String           @id @default(cuid())
  runId        String
  nodeId       String
  nodeType     String
  nodeTitle    String?
  status       AiPathNodeStatus @default(pending)
  attempt      Int              @default(0)
  inputs       Json?
  outputs      Json?
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  run          AiPathRun        @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, nodeId])
  @@index([runId])
  @@index([nodeId])
}

model AiPathRunEvent {
  id        String              @id @default(cuid())
  runId     String
  level     AiPathRunEventLevel @default(info)
  message   String
  metadata  Json?
  createdAt DateTime            @default(now())
  run       AiPathRun           @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([createdAt])
}

model ProductDraft {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  sku                 String?
  ean                 String?
  gtin                String?
  asin                String?
  name_en             String?
  name_pl             String?
  name_de             String?
  description_en      String?
  description_pl      String?
  description_de      String?
  weight              Int?
  sizeLength          Int?
  sizeWidth           Int?
  length              Int?
  price               Int?
  supplierName        String?
  supplierLink        String?
  priceComment        String?
  stock               Int?
  catalogIds          Json     @default("[]")
  categoryId          String?
  tagIds              Json     @default("[]")
  parameters          Json     @default("[]")
  defaultPriceGroupId String?
  active              Boolean  @default(true)
  icon                String?
  imageLinks          Json     @default("[]")
  baseProductId       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ExternalCategory {
  id               String            @id @default(cuid())
  connectionId     String
  externalId       String
  name             String
  parentExternalId String?
  path             String?
  depth            Int               @default(0)
  isLeaf           Boolean           @default(true)
  metadata         Json?
  fetchedAt        DateTime          @default(now())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  mappings         CategoryMapping[]

  @@unique([connectionId, externalId])
  @@index([connectionId])
  @@index([parentExternalId])
}

model CategoryMapping {
  id                 String           @id @default(cuid())
  connectionId       String
  externalCategoryId String
  internalCategoryId String
  catalogId          String
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  externalCategory   ExternalCategory @relation(fields: [externalCategoryId], references: [id], onDelete: Cascade)
  internalCategory   ProductCategory  @relation(fields: [internalCategoryId], references: [id], onDelete: Cascade)

  @@unique([connectionId, externalCategoryId, catalogId])
  @@index([connectionId])
  @@index([internalCategoryId])
}

model Asset3D {
  id               String            @id @default(cuid())
  name             String?
  description      String?
  filename         String
  filepath         String
  mimetype         String
  size             Int
  tags             String[]          @default([])
  category         String?
  metadata         Json?
  isPublic         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  imageStudioSlots ImageStudioSlot[]

  @@index([category])
  @@index([isPublic])
}

model ImageStudioSlot {
  id               String     @id @default(cuid())
  projectId        String
  name             String
  folderPath       String     @default("")
  position         Int?
  imageFileId      String?
  imageUrl         String?
  imageBase64      String?
  asset3dId        String?
  screenshotFileId String?
  metadata         Json?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  asset3d          Asset3D?   @relation(fields: [asset3dId], references: [id])
  imageFile        ImageFile? @relation("ImageStudioSlotImage", fields: [imageFileId], references: [id])
  screenshotFile   ImageFile? @relation("ImageStudioSlotScreenshot", fields: [screenshotFileId], references: [id])

  @@index([projectId])
  @@index([folderPath])
}

enum CurrencyCode {
  USD
  EUR
  PLN
  GBP
  SEK
}

enum CountryCode {
  PL
  DE
  GB
  US
  SE
}

enum AgentRunStatus {
  queued
  running
  waiting_human
  stopped
  failed
  completed
}

enum AgentMemoryScope {
  session
  longterm
}

enum AgentAuditLevel {
  info
  warning
  error
}

enum ChatbotJobStatus {
  pending
  running
  completed
  failed
  canceled
}

enum ProductAiJobStatus {
  pending
  running
  completed
  failed
  canceled
}

enum AiPathRunStatus {
  queued
  running
  paused
  completed
  failed
  canceled
  dead_lettered
}

enum AiPathNodeStatus {
  pending
  running
  completed
  failed
  skipped
  blocked
}

enum AiPathRunEventLevel {
  info
  warning
  error
}
