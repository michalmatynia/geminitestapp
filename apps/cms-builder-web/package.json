{
  "name": "@app/cms-builder-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/runtime/run-cms-builder-web-next.cjs dev --port 3200",
    "build": "node ../../scripts/runtime/run-cms-builder-web-next.cjs build",
    "start": "node ../../scripts/runtime/run-cms-builder-web-next.cjs start --port 3200",
    "test": "vitest --root ../.. run apps/cms-builder-web/src",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false",
    "mongo:up": "MONGODB_PORT=27019 node ../../scripts/db/local-mongo.mjs up",
    "mongo:down": "MONGODB_PORT=27019 node ../../scripts/db/local-mongo.mjs down",
    "mongo:status": "MONGODB_PORT=27019 node ../../scripts/db/local-mongo.mjs status",
    "mongo:copy-from-root:plan": "node ../../scripts/db/copy-cms-builder-local-mongo.mjs",
    "mongo:copy-from-root": "node ../../scripts/db/copy-cms-builder-local-mongo.mjs --apply",
    "mongo:detach-root:plan": "node ../../scripts/db/detach-cms-builder-root-mongo.mjs",
    "mongo:detach-root": "node ../../scripts/db/detach-cms-builder-root-mongo.mjs --apply --confirm=detach-cms-builder-from-root",
    "mongo:restore-root:plan": "node ../../scripts/db/restore-cms-builder-root-mongo.mjs",
    "mongo:restore-root": "node ../../scripts/db/restore-cms-builder-root-mongo.mjs --apply --confirm=restore-cms-builder-root"
  },
