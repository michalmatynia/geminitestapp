{
  "name": "libapp2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/runtime/check-node-version.cjs",
    "dev": "node --max-old-space-size=8192 server.cjs",
    "dev:heap": "node --max-old-space-size=8192 --heapsnapshot-near-heap-limit=2 --trace-gc server.cjs",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "NODE_ENV=production node --max-old-space-size=4096 server.cjs",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit --incremental false",
    "seed": "node prisma/seed.js",
    "seed:admin": "tsx scripts/db/seed-admin.ts",
    "backfill:ai-paths-input-contracts": "tsx scripts/db/backfill-ai-paths-input-contracts.ts",
    "backfill:ai-paths-sanitize-edges": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/db/backfill-ai-paths-sanitize-edges.ts",
    "backfill:ai-path-run-runtime-ports": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/db/backfill-ai-path-run-runtime-ports.ts",
    "backfill:image-studio-center-links": "tsx scripts/db/backfill-image-studio-center-links.ts",
    "backfill:image-studio-upscale-links": "tsx scripts/db/backfill-image-studio-upscale-links.ts",
    "products:normalize:v2": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/db/normalize-products-v2.ts",
    "restore:base-listing-statuses": "tsx scripts/db/restore-base-listing-statuses.ts",
    "cleanup:db-providers": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/cleanup/cleanup-db-provider-settings.ts",
    "cleanup:cms-blocks": "tsx scripts/db/drop-cms-blocks.ts",
    "cleanup:category-mapping-duplicates": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/cleanup/reconcile-category-mapping-duplicates.ts",
    "cleanup:image-studio-orphan-variants": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/cleanup/reconcile-image-studio-orphan-variant-slots.ts",
    "check:api-error-sources": "tsx scripts/debug/check-api-error-sources.ts",
    "observability:scan": "node scripts/observability/check-observability.mjs --mode=scan",
    "observability:check": "node scripts/observability/check-observability.mjs --mode=check",
    "storage:configure:fastcomet": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/db/configure-fastcomet-storage.ts",
    "storage:migrate:fastcomet": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/db/migrate-uploads-to-fastcomet.ts",
    "metrics:collect": "node scripts/architecture/collect-metrics.mjs",
    "metrics:guardrails": "node scripts/architecture/check-guardrails.mjs",
    "metrics:guardrails:update": "node scripts/architecture/check-guardrails.mjs --update-baseline",
    "metrics:hotspots": "node scripts/perf/route-hotspots.mjs",
    "metrics:all": "npm run metrics:collect && npm run metrics:hotspots && npm run metrics:guardrails",
    "docs:validator:generate": "tsx scripts/docs/generate-validator-docs.ts",
    "docs:validator:check": "tsx scripts/docs/check-validator-doc-coverage.ts",
    "docs:ai-paths:semantic:generate": "tsx scripts/docs/generate-ai-paths-semantic-grammar.ts",
    "docs:ai-paths:semantic:check": "tsx scripts/docs/check-ai-paths-semantic-grammar.ts",
    "docs:ai-paths:tooltip:generate": "tsx scripts/docs/generate-ai-paths-tooltip-catalog.ts",
    "docs:ai-paths:tooltip:check": "tsx scripts/docs/check-ai-paths-tooltip-coverage.ts",
    "check:factory-meta": "node scripts/query/check-factory-meta.cjs",
    "check:factory-meta:strict": "CHECK_FACTORY_META_STRICT_ALIAS=1 node scripts/query/check-factory-meta.cjs",
    "auth:indexes": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/db/ensure-auth-indexes.ts",
    "debug": "tsx scripts/debug/debug-script.ts",
    "test": "npm run test:unit",
    "test:unit": "vitest run --project unit",
    "test:integration:prisma": "npm run test:preflight:prisma && vitest run --project integration-prisma",
    "test:integration:mongo": "vitest run --project integration-mongo",
    "test:preflight:prisma": "prisma migrate status && tsx scripts/testing/check-prisma-test-db.ts",
    "test:ci": "npm run test:unit && npm run test:integration:prisma && npm run test:integration:mongo",
    "test:ui": "vitest --ui --project unit",
    "test:coverage": "vitest --coverage",
    "test:case-resolver:regression": "vitest run src/features/case-resolver/__tests__/workspace-persist-queue.test.ts src/features/case-resolver/__tests__/workspace-persistence.test.ts src/features/case-resolver/__tests__/workspace-observability.test.ts src/features/case-resolver/__tests__/ocr-queue-model-routing.test.ts src/features/case-resolver/__tests__/ocr-runtime.test.ts src/features/case-resolver/__tests__/ocr-observability.test.ts src/features/case-resolver/__tests__/prompt-exploder-sync-target.test.ts src/features/case-resolver/__tests__/prompt-exploder-capture-modal.test.tsx src/features/case-resolver/__tests__/capture-mapping-apply-guard.test.ts src/features/case-resolver-capture/__tests__/proposals.test.ts",
    "test:e2e:case-resolver:capture-mapping": "playwright test e2e/features/case-resolver/case-resolver.spec.ts --grep \"capture mapping\"",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=20.9 <24",
    "npm": ">=10"
  },
