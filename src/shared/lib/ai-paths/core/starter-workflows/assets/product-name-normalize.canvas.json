    {
      "id": "node-category-context-name-normalize",
      "type": "function",
      "title": "Function",
      "description": "Reduce live product_categories rows into prompt-safe leaf-category context and current-category evidence.",
      "position": {
        "x": 1130,
        "y": 700
      },
      "inputs": ["bundle", "context"],
      "outputs": ["bundle"],
      "config": {
        "function": {
          "script": "const product = inputs.bundle && typeof inputs.bundle === 'object' ? inputs.bundle : {};\nconst liveContext =\n  inputs.context && typeof inputs.context === 'object' && inputs.context.liveContext && typeof inputs.context.liveContext === 'object'\n    ? inputs.context.liveContext\n    : {};\nconst collectionMap =\n  liveContext.collectionMap && typeof liveContext.collectionMap === 'object'\n    ? liveContext.collectionMap\n    : {};\nconst categoryCollection =\n  collectionMap.product_categories && typeof collectionMap.product_categories === 'object'\n    ? collectionMap.product_categories\n    : {};\nconst rawDocuments = Array.isArray(categoryCollection.documents) ? categoryCollection.documents : [];\n\nconst normalizeLabel = (doc) => {\n  if (!doc || typeof doc !== 'object') return '';\n  return String(doc.leafLabel || doc.name_en || doc.name || doc.name_pl || doc.name_de || doc.id || doc._id || '').trim();\n};\n\nconst normalizedCategories = rawDocuments\n  .map((doc) => {\n    const id = typeof doc.id === 'string' && doc.id.trim() ? doc.id.trim() : typeof doc._id === 'string' && doc._id.trim() ? doc._id.trim() : '';\n    if (!id) return null;\n    const label = normalizeLabel(doc);\n    return {\n      id,\n      label: label || id,\n      parentId: typeof doc.parentId === 'string' && doc.parentId.trim() ? doc.parentId.trim() : null,\n      catalogId: typeof doc.catalogId === 'string' && doc.catalogId.trim() ? doc.catalogId.trim() : null,\n      sortIndex: typeof doc.sortIndex === 'number' ? doc.sortIndex : null,\n      fullPath: typeof doc.fullPath === 'string' && doc.fullPath.trim() ? doc.fullPath.trim() : null,\n    };\n  })\n  .filter(Boolean);\n\nconst byId = Object.fromEntries(normalizedCategories.map((category) => [category.id, category]));\nconst childrenByParent = normalizedCategories.reduce((acc, category) => {\n  const parentKey = category.parentId || '__root__';\n  acc[parentKey] = (acc[parentKey] || 0) + 1;\n  return acc;\n}, {});\n\nconst buildFullPath = (categoryId, seen = new Set()) => {\n  const category = byId[categoryId];\n  if (!category) return '';\n  if (category.fullPath) return category.fullPath;\n  if (seen.has(categoryId)) return category.label;\n  const nextSeen = new Set(seen);\n  nextSeen.add(categoryId);\n  if (!category.parentId || !byId[category.parentId]) return category.label;\n  const parentPath = buildFullPath(category.parentId, nextSeen);\n  return parentPath ? `${parentPath} > ${category.label}` : category.label;\n};\n\nconst leafCategories = normalizedCategories\n  .filter((category) => !childrenByParent[category.id])\n  .map((category) => ({\n    id: category.id,\n    label: category.label,\n    fullPath: buildFullPath(category.id),\n    parentId: category.parentId,\n    isCurrent: category.id === product.categoryId,\n  }))\n  .sort((left, right) => left.fullPath.localeCompare(right.fullPath));\n\nconst currentCategoryId =\n  typeof product.categoryId === 'string' && product.categoryId.trim() ? product.categoryId.trim() : null;\nconst currentCategoryBase = currentCategoryId ? byId[currentCategoryId] || null : null;\nconst currentCategory = currentCategoryBase\n  ? {\n      id: currentCategoryBase.id,\n      label: currentCategoryBase.label,\n      fullPath: buildFullPath(currentCategoryBase.id),\n      isLeaf: !childrenByParent[currentCategoryBase.id],\n    }\n  : null;\n\nreturn {\n  bundle: {\n    ...product,\n    categoryContext: {\n      collection: 'product_categories',\n      catalogId: typeof product.catalogId === 'string' && product.catalogId.trim() ? product.catalogId.trim() : null,\n      currentCategoryId,\n      currentCategory,\n      leafCategories,\n      allowedLeafLabels: leafCategories.map((category) => category.label),\n      totalCategories: normalizedCategories.length,\n      totalLeafCategories: leafCategories.length,\n      fetchedAt:\n        typeof liveContext.fetchedAt === 'string' && liveContext.fetchedAt.trim()\n          ? liveContext.fetchedAt\n          : null,\n    },\n  },\n};",
          "safeMode": true,
          "expectedType": "object",
          "maxExecutionMs": 1000,
          "maxOutputBytes": 65536
        },
        "runtime": {
          "waitForInputs": true,
          "inputContracts": {
