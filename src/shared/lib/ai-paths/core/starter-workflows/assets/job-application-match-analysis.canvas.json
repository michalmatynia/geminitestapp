    {
      "id": "node-parser-job-application-match-analysis",
      "type": "parser",
      "title": "JSON Parser",
      "description": "Extract prepared application, person, CV, education, job, organisation, and platform contexts.",
      "position": {
        "x": 500,
        "y": 240
      },
      "inputs": [
        "entityJson",
        "context"
      ],
      "outputs": [
        "bundle",
        "applicationRecord",
        "personContext",
        "jobContext",
        "organizationContext",
        "platformContext",
        "analysisRequest",
        "outputContract"
      ],
      "config": {
        "parser": {
          "mappings": {
            "applicationRecord": "$.applicationContext.applicationRecord",
            "personContext": "$.applicationContext.personContext",
            "jobContext": "$.applicationContext.jobContext",
            "organizationContext": "$.applicationContext.organizationContext",
            "platformContext": "$.applicationContext.platformContext",
