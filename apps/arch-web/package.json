{
  "name": "@app/arch-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack --port 3400",
    "build": "next build --webpack",
    "start": "next start --port 3400",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false",
    "mongo:arch:up": "MONGODB_PORT=27022 MONGODB_DATA_DIR=../../../database/arch-mongo-data MONGODB_RUNTIME_DIR=../../../database/arch-mongo-runtime node ../../scripts/db/local-mongo.mjs up",
    "mongo:arch:down": "MONGODB_PORT=27022 MONGODB_DATA_DIR=../../../database/arch-mongo-data MONGODB_RUNTIME_DIR=../../../database/arch-mongo-runtime node ../../scripts/db/local-mongo.mjs down",
    "mongo:arch:status": "MONGODB_PORT=27022 MONGODB_DATA_DIR=../../../database/arch-mongo-data MONGODB_RUNTIME_DIR=../../../database/arch-mongo-runtime node ../../scripts/db/local-mongo.mjs status",
    "seed": "node --experimental-transform-types scripts/seed.ts"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.15.0",
    "mongodb": "^6.21.0",
    "next": "16.1.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "^0.155.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.155.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
  }
}
