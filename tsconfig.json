{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@kangur/contracts": [
        "./packages/kangur-contracts/src/index.ts"
      ],
      "@kangur/contracts/*": [
        "./packages/kangur-contracts/src/*"
      ],
      "@kangur/core": [
        "./packages/kangur-core/src/index.ts"
      ],
      "@kangur/core/*": [
        "./packages/kangur-core/src/*"
      ],
      "@kangur/api-client": [
        "./packages/kangur-api-client/src/index.ts"
      ],
      "@kangur/api-client/*": [
        "./packages/kangur-api-client/src/*"
      ],
      "@kangur/platform": [
        "./packages/kangur-platform/src/index.ts"
      ],
      "@kangur/platform/*": [
        "./packages/kangur-platform/src/*"
      ],
      "@/*": [
        "./src/*"
      ],
      "@docs/*": [
        "./docs/*"
      ],
      "@/__tests__/*": [
        "./__tests__/*"
      ],
      "pg": [
        "./src/shared/lib/db/pg-stub.ts"
      ],
      "gsap/ScrollTrigger": [
        "./node_modules/gsap/types/scroll-trigger.d.ts"
      ],
      "gsap/MotionPathPlugin": [
        "./node_modules/gsap/types/motion-path-plugin.d.ts"
      ],
      "gsap/Flip": [
        "./node_modules/gsap/types/flip.d.ts"
      ],
      "gsap/Draggable": [
        "./node_modules/gsap/types/draggable.d.ts"
      ],
      "gsap/CustomEase": [
        "./node_modules/gsap/types/custom-ease.d.ts"
      ],
      "gsap/Observer": [
        "./node_modules/gsap/types/observer.d.ts"
      ]
    },
    "types": [
      "vitest/globals",
      "react",
      "react-dom",
      "react-error-boundary",
      "@tanstack/react-query-devtools",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "types/**/*.d.ts",
    ".next/types/**/*.ts",
    "src/global.d.ts",
    "src/shared/contracts/ambient.d.ts",
    ".next/dev/types/**/*.ts",
    ".next-dev/types/**/*.ts",
    ".next-dev/dev/types/**/*.ts",
    ".next-dev-*/types/**/*.ts",
    ".next-dev-*/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "apps",
    "packages",
    ".next",
    ".next-dev",
    ".next-dev-*",
    "bazel-*",
    "bazel-bin",
    "bazel-out",
    "bazel-testlogs",
    "tmp_merged_test.tsx",
    "tmp",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
