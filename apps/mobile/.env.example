# Optional local API override for Expo web and native development.
# iOS simulator: localhost is fine.
# Android emulator: use http://10.0.2.2:3000
# Physical device: use a reachable LAN IP or tunnel URL, not localhost.
EXPO_PUBLIC_KANGUR_API_URL=http://localhost:3000

# Force learner-session mode when validating the real mobile auth flow.
EXPO_PUBLIC_KANGUR_AUTH_MODE=learner-session

# Replace these placeholder identifiers before running preview or production EAS builds.
KANGUR_IOS_BUNDLE_IDENTIFIER=com.example.kangur.mobile
KANGUR_ANDROID_PACKAGE=com.example.kangur.mobile

# Set these when wiring the app to a real Expo/EAS project.
KANGUR_EXPO_OWNER=your-expo-account
KANGUR_EXPO_PROJECT_ID=123e4567-e89b-42d3-a456-426614174000
