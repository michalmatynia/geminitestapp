{
  "name": "@app/studiq-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/runtime/run-studiq-web-next.cjs dev --webpack --port 3100",
    "build": "node ../../scripts/runtime/run-studiq-web-next.cjs build",
    "start": "node ../../scripts/runtime/run-studiq-web-next.cjs start --port 3100",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false",
    "mongo:up": "MONGODB_PORT=27018 node ../../scripts/db/local-mongo.mjs up",
    "mongo:down": "MONGODB_PORT=27018 node ../../scripts/db/local-mongo.mjs down",
    "mongo:status": "MONGODB_PORT=27018 node ../../scripts/db/local-mongo.mjs status",
    "mongo:copy-from-root:plan": "node ../../scripts/db/copy-studiq-local-mongo.mjs",
    "mongo:copy-from-root": "node ../../scripts/db/copy-studiq-local-mongo.mjs --apply",
    "mongo:detach-root:plan": "node ../../scripts/db/detach-studiq-root-mongo.mjs",
    "mongo:detach-root": "node ../../scripts/db/detach-studiq-root-mongo.mjs --apply --confirm=detach-studiq-from-root",
    "mongo:restore-root:plan": "node ../../scripts/db/restore-studiq-root-mongo.mjs",
    "mongo:restore-root": "node ../../scripts/db/restore-studiq-root-mongo.mjs --apply --confirm=restore-studiq-root"
  },
  "dependencies": {
    "@auth/mongodb-adapter": "^3.11.2",
    "@kangur/api-client": "file:../../packages/kangur-api-client",
    "@kangur/contracts": "file:../../packages/kangur-contracts",
    "@kangur/core": "file:../../packages/kangur-core",
    "@kangur/platform": "file:../../packages/kangur-platform",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.10.1",
    "mongodb": "^7.2.0",
    "next": "^16.2.6",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.12.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  },
  "browserslist": [
    "chrome >= 100",
    "firefox >= 100",
    "safari >= 15.4",
    "edge >= 100",
    "not dead"
  ]
}
