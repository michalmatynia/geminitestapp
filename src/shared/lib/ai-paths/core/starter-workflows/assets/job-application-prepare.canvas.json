    "id": "path_job_application_prepare_v1",
    "version": 1,
    "name": "Prepare Job Application",
    "description": "Create a tailored CV and cover letter from a Persons profile, job listing, and organisation profile.",
    "trigger": "Organisation Job Row - Create Application",
    "updatedAt": "2026-04-29T00:00:00.000Z",
    "executionMode": "server",
    "flowIntensity": "medium",
    "runMode": "block",
    "strictFlowMode": true,
    "isLocked": false,
    "isActive": true
  },
  "nodes": [
    {
      "id": "node-trigger-job-application-prepare",
      "type": "trigger",
      "title": "Trigger: Create Application",
      "description": "Fire job application preparation from the Organisation job row modal.",
      "position": {
        "x": 24,
        "y": 240
      },
      "inputs": [],
      "outputs": ["trigger", "triggerName"],
      "config": {
        "trigger": {
          "event": "cb9f76f4-50d5-4d23-8f89-f11d4f7f81dd",
          "contextMode": "trigger_only"
        }
      }
    },
    {
      "id": "node-fetcher-job-application-prepare",
      "type": "fetcher",
      "title": "Fetcher: Trigger Context",
      "description": "Resolve the job application context embedded by the modal.",
      "position": {
        "x": 240,
        "y": 240
      },
      "inputs": ["trigger", "context", "meta", "entityId", "entityType"],
      "outputs": ["context", "meta", "entityId", "entityType"],
      "config": {
        "fetcher": {
          "sourceMode": "live_context",
          "entityType": "custom",
          "entityId": ""
        },
        "runtime": {
          "waitForInputs": true,
          "inputContracts": {
            "trigger": {
              "required": true
            },
            "context": {
              "required": false
            },
            "meta": {
              "required": false
            },
            "entityId": {
              "required": false
            },
            "entityType": {
              "required": false
            }
          }
        }
      }
    },
    {
      "id": "node-parser-job-application-prepare",
      "type": "parser",
      "title": "JSON Parser",
      "description": "Extract person, CV, job, organisation, and platform contexts.",
      "position": {
        "x": 500,
        "y": 240
      },
      "inputs": ["entityJson", "context"],
      "outputs": [
        "bundle",
        "personContext",
        "jobContext",
        "organizationContext",
        "platformContext",
        "generationRequest",
        "outputContract"
      ],
      "config": {
        "parser": {
          "mappings": {
            "personContext": "$.applicationContext.personContext",
            "jobContext": "$.applicationContext.jobContext",
            "organizationContext": "$.applicationContext.organizationContext",
            "platformContext": "$.applicationContext.platformContext",
            "generationRequest": "$.applicationContext.generationRequest",
            "outputContract": "$.applicationContext.outputContract"
          },
          "outputMode": "bundle",
          "presetId": "custom"
        }
      }
    },
    {
      "id": "node-prompt-job-application-prepare",
      "type": "prompt",
      "title": "Prompt",
      "description": "Build a grounded application-writing prompt.",
      "position": {
        "x": 880,
        "y": 240
      },
      "inputs": ["bundle", "context"],
      "outputs": ["prompt", "images"],
      "config": {
        "prompt": {
          "template": "Create a tailored job application package from the provided database context.\n\nPerson context JSON: {{bundle.personContext}}\nJob listing context JSON: {{bundle.jobContext}}\nOrganisation context JSON: {{bundle.organizationContext}}\nPlatform context JSON: {{bundle.platformContext}}\nGeneration request JSON: {{bundle.generationRequest}}\n\nReturn ONLY valid JSON with this exact schema:\n{\"tailoredCv\":{\"title\":\"\",\"professionalSummary\":\"\",\"bodyText\":\"\",\"bodyMarkdown\":\"\",\"experienceHighlights\":[\"\"],\"educationHighlights\":[\"\"],\"skills\":[\"\"],\"preferencesMatch\":[\"\"]},\"coverLetter\":{\"subject\":\"\",\"bodyMarkdown\":\"\"},\"applicationNotes\":[\"\"],\"missingInformation\":[\"\"],\"confidence\":0}\n\nRules:\n1. Tailor the CV and cover letter to the specific job listing and organisation profile.\n2. Use only facts present in the person profile, person linked records, and existing CV database records.\n3. Prefer the person's education, experience, strengths, technical environment, and preferences when they are relevant.\n4. Do not claim employment history, education, technologies, languages, certifications, or achievements that are not in the context.\n5. Build tailoredCv.bodyText as a complete plain text CV and tailoredCv.bodyMarkdown as the same CV in markdown.\n6. If the job or organisation context is thin, explain the missing information in missingInformation instead of inventing it.\n7. Keep the cover letter professional, direct, and specific to the company and role.\n8. Return JSON only. No markdown outside bodyMarkdown fields, no code fences, no commentary."
        }
      }
    },
    {
      "id": "node-model-job-application-prepare",
      "type": "model",
      "title": "Model",
      "description": "Generate the tailored CV and cover letter.",
      "position": {
        "x": 1280,
        "y": 240
      },
      "inputs": ["prompt", "images", "context"],
      "outputs": ["result", "jobId"],
      "config": {
        "model": {
          "temperature": 0.2,
          "maxTokens": 2200,
          "vision": false,
          "waitForResult": true
        }
      }
    },
    {
      "id": "node-regex-job-application-prepare",
      "type": "regex",
      "title": "Regex JSON Extract",
      "description": "Parse the application package JSON response.",
      "position": {
        "x": 1660,
        "y": 240
      },
      "inputs": ["value", "prompt", "regexCallback"],
      "outputs": ["grouped", "matches", "value", "aiPrompt"],
      "config": {
        "regex": {
          "pattern": "\\{[\\s\\S]*\\}",
          "flags": "",
          "mode": "extract_json",
          "matchMode": "first_overall",
          "groupBy": "match",
          "outputMode": "object",
          "includeUnmatched": false,
          "unmatchedKey": "__unmatched__",
          "splitLines": false,
          "sampleText": "",
          "aiPrompt": "",
          "aiAutoRun": false,
          "activeVariant": "manual",
          "jsonIntegrityPolicy": "repair"
        },
        "runtime": {
          "waitForInputs": true
        }
      }
    },
    {
      "id": "node-db-insert-cv-job-application-prepare",
      "type": "database",
      "title": "Persist Tailored CV",
      "description": "Save the generated tailored CV against the selected Person record.",
      "position": {
        "x": 2040,
        "y": 88
      },
      "inputs": ["value", "context"],
      "outputs": ["result", "bundle"],
      "config": {
        "database": {
          "operation": "insert",
          "entityType": "filemaker_cv",
          "mode": "replace",
          "useMongoActions": true,
          "actionCategory": "create",
          "action": "insertOne",
          "query": {
            "provider": "mongodb",
            "collection": "filemaker_cvs",
            "mode": "custom",
            "preset": "by_id",
            "field": "id",
            "idType": "string",
            "queryTemplate": "{\"_id\":\"ai-filemaker-cv-{{context.entityId}}-{{context.timestamp}}\",\"id\":\"ai-filemaker-cv-{{context.entityId}}-{{context.timestamp}}\",\"personId\":\"{{context.entityJson.applicationContext.personContext.selectedPersonId}}\",\"personName\":\"{{context.entityJson.applicationContext.personContext.person.fullName}}\",\"title\":\"{{value.tailoredCv.title}}\",\"status\":\"draft\",\"template\":\"classic\",\"bodyBlocks\":[],\"bodyHtml\":null,\"bodyText\":\"{{value.tailoredCv.bodyText}}\",\"bodyMarkdown\":\"{{value.tailoredCv.bodyMarkdown}}\",\"professionalSummary\":\"{{value.tailoredCv.professionalSummary}}\",\"experienceHighlights\":{{value.tailoredCv.experienceHighlights}},\"educationHighlights\":{{value.tailoredCv.educationHighlights}},\"skills\":{{value.tailoredCv.skills}},\"preferencesMatch\":{{value.tailoredCv.preferencesMatch}},\"source\":\"ai-path-job-application-prepare\",\"sourceEntityId\":\"{{context.entityId}}\",\"jobListingId\":\"{{context.entityJson.applicationContext.jobContext.selectedJobListingId}}\",\"organizationId\":\"{{context.entityJson.applicationContext.organizationContext.selectedOrganizationId}}\",\"integrationSlug\":\"{{context.entityJson.applicationContext.platformContext.integrationSlug}}\",\"createdAt\":\"{{context.timestamp}}\",\"updatedAt\":\"{{context.timestamp}}\"}",
            "limit": 1,
            "sort": "",
            "projection": "",
            "single": true
          },
          "writeOutcomePolicy": {
            "onZeroAffected": "fail"
          }
        },
        "runtime": {
          "waitForInputs": true
        }
      }
    },
    {
      "id": "node-db-insert-application-job-application-prepare",
      "type": "database",
      "title": "Persist Application Package",
      "description": "Save the full generated job application package, including cover letter and context metadata.",
      "position": {
        "x": 2040,
        "y": 392
      },
      "inputs": ["value", "context"],
      "outputs": ["result", "bundle"],
      "config": {
        "database": {
          "operation": "insert",
          "entityType": "filemaker_job_application",
          "mode": "replace",
          "useMongoActions": true,
          "actionCategory": "create",
          "action": "insertOne",
          "query": {
            "provider": "mongodb",
            "collection": "filemaker_job_applications",
            "mode": "custom",
            "preset": "by_id",
            "field": "id",
            "idType": "string",
            "queryTemplate": "{\"_id\":\"ai-job-application-{{context.entityId}}-{{context.timestamp}}\",\"id\":\"ai-job-application-{{context.entityId}}-{{context.timestamp}}\",\"status\":\"draft\",\"personId\":\"{{context.entityJson.applicationContext.personContext.selectedPersonId}}\",\"personName\":\"{{context.entityJson.applicationContext.personContext.person.fullName}}\",\"organizationId\":\"{{context.entityJson.applicationContext.organizationContext.selectedOrganizationId}}\",\"organizationName\":\"{{context.entityJson.applicationContext.organizationContext.organization.name}}\",\"jobListingId\":\"{{context.entityJson.applicationContext.jobContext.selectedJobListingId}}\",\"jobTitle\":\"{{context.entityJson.applicationContext.jobContext.listing.title}}\",\"integrationId\":\"{{context.entityJson.applicationContext.platformContext.integrationId}}\",\"integrationSlug\":\"{{context.entityJson.applicationContext.platformContext.integrationSlug}}\",\"connectionId\":\"{{context.entityJson.applicationContext.platformContext.connectionId}}\",\"tailoredCvId\":\"ai-filemaker-cv-{{context.entityId}}-{{context.timestamp}}\",\"tailoredCv\":{{value.tailoredCv}},\"coverLetter\":{{value.coverLetter}},\"applicationNotes\":{{value.applicationNotes}},\"missingInformation\":{{value.missingInformation}},\"confidence\":{{value.confidence}},\"source\":\"ai-path-job-application-prepare\",\"sourceEntityId\":\"{{context.entityId}}\",\"sourceApplicationContext\":{{context.entityJson.applicationContext}},\"createdAt\":\"{{context.timestamp}}\",\"updatedAt\":\"{{context.timestamp}}\"}",
            "limit": 1,
            "sort": "",
            "projection": "",
            "single": true
          },
          "writeOutcomePolicy": {
            "onZeroAffected": "fail"
          }
        },
        "runtime": {
          "waitForInputs": true
        }
      }
    },
    {
      "id": "node-view-job-application-prepare",
      "type": "viewer",
      "title": "Application Package",
      "description": "Inspect the generated tailored CV and cover letter.",
      "position": {
        "x": 2440,
        "y": 240
      },
      "inputs": [
        "bundle",
        "cvPersistence",
        "applicationPersistence",
        "context",
        "prompt",
        "entityId",
        "entityType",
        "meta"
      ],
      "outputs": [],
      "config": {
        "viewer": {
          "outputs": {
            "bundle": "",
            "cvPersistence": "",
            "applicationPersistence": "",
            "context": "",
            "prompt": "",
            "entityId": "",
            "entityType": "",
            "meta": ""
          }
        }
      }
    }
