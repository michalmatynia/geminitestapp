#!/usr/bin/env bash
set -euo pipefail

cd "$HOME/Desktop/NPM/2026/Gemini new Pull/geminitestapp"

# GEMINI_CMD can be:
#   gemini
#   npx -y @google/gemini-cli
GEMINI_CMD="${GEMINI_CMD:-gemini}"
APPROVAL_MODE="${APPROVAL_MODE:-yolo}"
MAX_RETRIES="${MAX_RETRIES:-50}"
SLEEP_SECONDS="${SLEEP_SECONDS:-10}"
MODEL="${MODEL:-}" # optional

# Prompt can be passed as args or stdin
if [[ $# -gt 0 ]]; then
  PROMPT="$*"
else
  PROMPT="$(cat)"
fi

run_once() {
  run_once() {
  # Run through a login shell so:
  # - GEMINI_CMD can include arguments (e.g. "npx -y @google/gemini-cli")
  # - your nvm PATH is loaded (so npx/node work inside scripts)
  if [[ -n "$MODEL" ]]; then
    bash -lc "$GEMINI_CMD -p $(printf '%q' "$PROMPT") --output-format json --approval-mode $(printf '%q' "$APPROVAL_MODE") -m $(printf '%q' "$MODEL")"
  else
    bash -lc "$GEMINI_CMD -p $(printf '%q' "$PROMPT") --output-format json --approval-mode $(printf '%q' "$APPROVAL_MODE")"
  fi
}

extract_json() {
  python3 - <<'PY'
import sys, re, json
s = sys.stdin.read()
# try last {...} block
m = list(re.finditer(r'\{.*\}\s*$', s, flags=re.S))
if not m:
  m = list(re.finditer(r'\{.*\}', s, flags=re.S))
if not m:
  print("__NOJSON__")
  sys.exit(0)
jtxt = m[-1].group(0)
try:
  j = json.loads(jtxt)
except Exception:
  print("__BADJSON__")
  sys.exit(0)
print(json.dumps(j))
PY
}

for ((i=1; i<=MAX_RETRIES; i++)); do
  echo "[gemini] Attempt $i/$MAX_RETRIES..."

  OUT="$(run_once 2>&1 || true)"
  J="$(printf "%s" "$OUT" | extract_json)"

  # If no JSON, fall back to text detection
  if [[ "$J" == "__NOJSON__" || "$J" == "__BADJSON__" ]]; then
    if echo "$OUT" | grep -qi "We are currently experiencing high demand"; then
      echo "[gemini] High demand detected (non-JSON). Sleeping ${SLEEP_SECONDS}s..."
      sleep "$SLEEP_SECONDS"
      continue
    fi
    echo "[gemini] Non-JSON error/output:"
    echo "$OUT"
    exit 2
  fi

  # Parse error message if present
  ERR_MSG="$(python3 - <<'PY' "$J"
import json,sys
j=json.loads(sys.argv[1])
err=j.get("error") or {}
print((err.get("message") or "").strip())
PY
)"

  if [[ -n "$ERR_MSG" ]] && echo "$ERR_MSG" | grep -qi "high demand"; then
    echo "[gemini] High demand detected. Sleeping ${SLEEP_SECONDS}s..."
    sleep "$SLEEP_SECONDS"
    continue
  fi

  # Success: print response and exit
  python3 - <<'PY' "$J"
import json,sys
j=json.loads(sys.argv[1])
print((j.get("response") or "").rstrip())
PY
  exit 0
done

echo "[gemini] Max retries reached ($MAX_RETRIES). Exiting."
exit 1
