            "queryTemplate": "{\"canonicalApplicationKey\":\"{{context.entityJson.applicationContext.personContext.selectedPersonId}}::{{context.entityJson.applicationContext.organizationContext.selectedOrganizationId}}::{{context.entityJson.applicationContext.jobContext.selectedJobListingId}}::{{context.entityJson.applicationContext.platformContext.integrationSlug}}\"}",
            "limit": 1,
            "sort": "",
