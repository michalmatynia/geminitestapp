# Copy this file to .env.local and fill in your values.
# The ecom-web app should use the thin ecommerce MongoDB file locally.
# Product List in geminitestapp keeps the full product database separately.

# MongoDB connection for ecommerce runtime data.
MONGODB_URI="mongodb://127.0.0.1:27021/ecom_local"
MONGODB_DB="ecom_local"
PRODUCTS_MONGODB_LOCAL_URI="mongodb://127.0.0.1:27021/ecom_local"
PRODUCTS_MONGODB_LOCAL_DB="ecom_local"
PRODUCTS_MONGODB_CLOUD_URI="mongodb+srv://user:password@cluster.example/products_db"
PRODUCTS_MONGODB_CLOUD_DB="products_db"
PRODUCTS_MONGODB_ACTIVE_SOURCE_DEFAULT="local"

# Ecommerce storefront product catalog database.
# Product List exports product copies here via "Export to Ecommerce".
ECOM_MONGODB_LOCAL_URI="mongodb://127.0.0.1:27021/ecom_local"
ECOM_MONGODB_LOCAL_DB="ecom_local"
ECOM_MONGODB_CLOUD_URI="mongodb+srv://user:password@cluster.example/ecom_db"
ECOM_MONGODB_CLOUD_DB="ecom_db"
ECOM_MONGODB_ACTIVE_SOURCE_DEFAULT="local"

# Optional catalog filter. Leave unset to show all active products in the selected product DB.
# MENTIOS_CATALOG_ID="catalog-mentios"

# Resend transactional email for order confirmations.
RESEND_API_KEY="re_..."

# Public URL of the ecom storefront — used for sitemap, robots.txt, and OG metadata.
# Set on Vercel to your production domain (e.g. https://arcana.example.com).
# Falls back to VERCEL_PROJECT_PRODUCTION_URL when not set.
# NEXT_PUBLIC_ECOM_URL="https://arcana.example.com"

# Optional: public file host for FastComet-backed product images.
# Set this on Vercel so /uploads/products/... records render from FastComet.
# NEXT_PUBLIC_FILE_BASE_URL="https://sparksofsindri.com"

# Optional: FastComet upload endpoint used by CMS image uploaders
# (header logo and homepage category selector images).
# If the main app has fastcomet_storage_config_v1 in MongoDB, the CMS can reuse it.
# FASTCOMET_STORAGE_BASE_URL="https://sparksofsindri.com"
# FASTCOMET_STORAGE_UPLOAD_URL="https://sparksofsindri.com/api/uploads/index.php"
# FASTCOMET_STORAGE_AUTH_TOKEN="replace-with-fastcomet-upload-token"
# FASTCOMET_STORAGE_TIMEOUT_MS="20000"

# Optional: base URL of the main app, used for local upload fallback while
# FastComet routing is being fixed in development.
# NEXT_PUBLIC_MAIN_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_FILE_FALLBACK_BASE_URL="http://localhost:3000"

# PayU BLIK payment gateway.
# Sign up at https://developers.payu.com and create a POS (point of sale).
# Use the sandbox URL for testing: https://secure.snd.payu.com
# Use the production URL for live: https://secure.payu.com
# PAYU_API_URL="https://secure.snd.payu.com"
# PAYU_POS_ID="your-pos-id"
# PAYU_CLIENT_ID="your-client-id"
# PAYU_CLIENT_SECRET="your-client-secret"
# PAYU_SECOND_KEY="your-second-key"        # Used to verify IPN webhook signatures
# NEXT_PUBLIC_BASE_URL="http://localhost:3001"  # Must be publicly reachable for IPN webhooks

# InPost ShipX shipping for Polish parcel lockers.
# Use sandbox for testing: https://sandbox-api-shipx-pl.easypack24.net
# Use production when live: https://api-shipx-pl.easypack24.net
# INPOST_API_URL="https://sandbox-api-shipx-pl.easypack24.net"
# INPOST_API_TOKEN="your-shipx-token"
# INPOST_ORGANIZATION_ID="your-organization-id"
# INPOST_DEFAULT_PARCEL_TEMPLATE="small"   # small | medium | large
# INPOST_SENDING_METHOD="dispatch_order"   # dispatch_order or parcel_locker
# NEXT_PUBLIC_INPOST_GEO_WIDGET_TOKEN="your-geowidget-token"

# InPost Group Shipping API v2, used for status refresh and label downloads.
# Stage: https://stage-api.inpost-group.com
# Production: https://api.inpost-group.com
# INPOST_GROUP_API_URL="https://stage-api.inpost-group.com"
# INPOST_OAUTH_TOKEN_URL="https://stage-api.inpost-group.com/oauth2/token"
# INPOST_OAUTH_CLIENT_ID="your-client-id"
# INPOST_OAUTH_CLIENT_SECRET="your-client-secret"
# Required OAuth scope for labels/status: openid api:shipments:read
# If INPOST_OAUTH_CLIENT_ID/SECRET are omitted, INPOST_API_TOKEN is reused as a Bearer token.

# InPost tracking webhook.
# Configure InPost to POST tracking events to:
#   https://your-domain.example/api/webhooks/inpost
# Use the same shared secret in InPost and here. Production rejects unsigned events.
# INPOST_WEBHOOK_SECRET="replace-with-inpost-hmac-shared-secret"
