      "config": {
        "database": {
          "operation": "update",
          "entityType": "product",
          "idField": "entityId",
          "mode": "replace",
          "updateStrategy": "one",
          "useMongoActions": true,
          "actionCategory": "update",
          "action": "findOneAndUpdate",
