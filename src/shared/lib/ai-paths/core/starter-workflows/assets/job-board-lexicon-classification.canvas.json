          "entitySnapshotMode": "always"
        }
      }
    },
    {
      "id": "node-fetcher-job-board-lexicon-classification",
      "type": "fetcher",
      "title": "Fetcher: Trigger Context",
      "description": "Resolve the embedded scraped offer and lexicon context.",
      "position": { "x": 240, "y": 240 },
      "inputs": ["trigger", "context", "meta", "entityId", "entityType"],
      "outputs": ["context", "meta", "entityId", "entityType"],
      "config": {
        "fetcher": {
          "sourceMode": "live_context",
          "entityType": "custom",
          "entityId": ""
        },
        "runtime": {
          "waitForInputs": true,
          "inputContracts": {
