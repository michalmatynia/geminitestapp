          "pattern": "\\{[\\s\\S]*\\}",
          "flags": "",
          "mode": "extract_json",
          "matchMode": "first_overall",
          "groupBy": "match",
          "outputMode": "object",
          "includeUnmatched": false,
          "unmatchedKey": "__unmatched__",
          "splitLines": false,
          "sampleText": "",
          "aiPrompt": "",
