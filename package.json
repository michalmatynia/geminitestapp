{
  "name": "libapp2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/runtime/check-node-version.cjs",
    "dev": "node --max-old-space-size=8192 server.cjs",
    "dev:heap": "node --max-old-space-size=8192 --heapsnapshot-near-heap-limit=2 --trace-gc server.cjs",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "NODE_ENV=production node --max-old-space-size=4096 server.cjs",
    "lint": "eslint src __tests__",
    "seed": "node prisma/seed.js",
    "seed:admin": "tsx scripts/db/seed-admin.ts",
    "backfill:image-studio-center-links": "tsx scripts/db/backfill-image-studio-center-links.ts",
    "backfill:image-studio-upscale-links": "tsx scripts/db/backfill-image-studio-upscale-links.ts",
    "cleanup:db-providers": "tsx scripts/cleanup/cleanup-db-provider-settings.ts",
    "cleanup:cms-blocks": "tsx scripts/db/drop-cms-blocks.ts",
    "cleanup:category-mapping-duplicates": "tsx scripts/cleanup/reconcile-category-mapping-duplicates.ts",
    "cleanup:image-studio-orphan-variants": "tsx scripts/cleanup/reconcile-image-studio-orphan-variant-slots.ts",
    "check:api-error-sources": "tsx scripts/debug/check-api-error-sources.ts",
    "storage:configure:fastcomet": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/db/configure-fastcomet-storage.ts",
    "storage:migrate:fastcomet": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/db/migrate-uploads-to-fastcomet.ts",
    "metrics:collect": "node scripts/architecture/collect-metrics.mjs",
    "metrics:guardrails": "node scripts/architecture/check-guardrails.mjs",
    "metrics:guardrails:update": "node scripts/architecture/check-guardrails.mjs --update-baseline",
    "metrics:hotspots": "node scripts/perf/route-hotspots.mjs",
    "metrics:all": "npm run metrics:collect && npm run metrics:hotspots && npm run metrics:guardrails",
    "docs:validator:generate": "tsx scripts/docs/generate-validator-docs.ts",
    "docs:validator:check": "tsx scripts/docs/check-validator-doc-coverage.ts",
    "check:factory-meta": "node scripts/query/check-factory-meta.cjs",
    "check:factory-meta:strict": "CHECK_FACTORY_META_STRICT_ALIAS=1 node scripts/query/check-factory-meta.cjs",
    "auth:indexes": "tsx scripts/db/ensure-auth-indexes.ts",
    "debug": "tsx scripts/debug/debug-script.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=20.9 <24",
    "npm": ">=10"
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@auth/mongodb-adapter": "^2.6.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@exodus/bytes": "^1.10.0",
    "@hookform/resolvers": "^5.2.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.3.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@tanstack/query-sync-storage-persister": "^5.90.22",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-query-persist-client": "^5.90.22",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-table-devtools": "^8.21.3",
    "@tiptap/extension-image": "^3.16.0",
    "@tiptap/extension-link": "^3.16.0",
    "@tiptap/extension-table": "^3.16.0",
    "@tiptap/extension-table-cell": "^3.16.0",
    "@tiptap/extension-table-header": "^3.16.0",
    "@tiptap/extension-table-row": "^3.16.0",
    "@tiptap/extension-task-item": "^3.16.0",
    "@tiptap/extension-task-list": "^3.16.0",
    "@tiptap/pm": "^3.16.0",
    "@tiptap/react": "^3.16.0",
    "@tiptap/starter-kit": "^3.16.0",
    "@types/turndown": "^5.0.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.67.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "gsap": "^3.14.2",
    "imagekit": "^6.0.0",
    "ioredis": "^5.9.2",
    "lru-cache": "^11.2.5",
    "lucide-react": "^0.562.0",
    "mongodb": "^6.10.0",
    "next": "^16.1.1",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "node-pty": "^1.1.0",
    "openai": "^6.15.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.3",
    "postprocessing": "^6.38.2",
    "prisma": "^7.3.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-easy-crop": "^5.5.6",
    "react-error-boundary": "^6.1.0",
    "react-hook-form": "^7.70.0",
    "react-syntax-highlighter": "^16.1.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.182.0",
    "turndown": "^7.2.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.0.3",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/supertest": "^6.0.3",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "autoprefixer": "^10.4.24",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.3.6",
    "jsdom": "^27.4.0",
    "msw": "^2.0.0",
    "node-mocks-http": "^1.17.2",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "shadcn": "^3.7.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  },
  "overrides": {
    "@auth/core": "0.41.1"
  }
}
