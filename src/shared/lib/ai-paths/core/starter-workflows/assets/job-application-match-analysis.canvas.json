          "temperature": 0.15,
          "maxTokens": 2600,
          "vision": false,
          "waitForResult": true,
          "modelId": "gpt-oss:120b-cloud"
        }
      }
    },
    {
      "id": "node-regex-job-application-match-analysis",
      "type": "regex",
      "title": "Regex JSON Extract",
      "description": "Parse the application package JSON response.",
      "position": {
        "x": 1660,
        "y": 240
      },
      "inputs": [
        "value",
        "prompt",
        "regexCallback"
      ],
      "outputs": [
        "grouped",
        "matches",
        "value",
        "aiPrompt"
      ],
      "config": {
        "regex": {
          "pattern": "\\{[\\s\\S]*\\}",
          "flags": "",
          "mode": "extract_json",
          "matchMode": "first_overall",
          "groupBy": "match",
          "outputMode": "object",
          "includeUnmatched": false,
          "unmatchedKey": "__unmatched__",
          "splitLines": false,
          "sampleText": "",
          "aiPrompt": "",
          "aiAutoRun": false,
          "activeVariant": "manual",
          "jsonIntegrityPolicy": "repair"
        },
        "runtime": {
          "waitForInputs": true
        }
      }
    },
    {
      "id": "node-db-insert-application-job-application-match-analysis",
      "type": "database",
      "title": "Persist Application Match Analysis",
      "description": "Save the generated candidate-job match analysis on the prepared application.",
      "position": {
        "x": 2040,
        "y": 392
      },
      "inputs": [
        "value",
        "context",
        "entityId"
      ],
      "outputs": [
        "result",
        "bundle"
      ],
      "config": {
        "database": {
          "operation": "update",
          "entityType": "filemaker_job_application",
          "mode": "replace",
          "useMongoActions": true,
          "actionCategory": "update",
          "action": "updateOne",
          "query": {
            "provider": "mongodb",
            "collection": "filemaker_job_applications",
            "mode": "custom",
            "preset": "by_id",
            "field": "id",
            "idType": "string",
            "queryTemplate": "{\"$or\":[{\"canonicalApplicationKey\":\"{{context.entityJson.applicationContext.applicationRecord.canonicalApplicationKey}}\"},{\"id\":\"{{context.entityJson.applicationContext.applicationRecord.id}}\"},{\"_id\":\"{{context.entityJson.applicationContext.applicationRecord.id}}\"}]}",
            "limit": 1,
            "sort": "",
            "projection": "",
            "single": true
          },
          "writeOutcomePolicy": {
            "onZeroAffected": "fail"
          },
          "upsert": false,
          "updatePayloadMode": "custom",
          "updateTemplate": "{\"$set\":{\"matchAnalysis\":{{value.matchAnalysis}},\"matchAnalysisUpdatedAt\":\"{{context.timestamp}}\",\"matchAnalysisSourceEntityId\":\"{{context.entityId}}\",\"matchAnalysisModelId\":\"{{context.entityJson.applicationContext.analysisRequest.modelId}}\",\"matchAnalysisStatus\":\"completed\",\"source\":\"ai-path-job-application-match-analysis\",\"sourceEntityId\":\"{{context.entityId}}\",\"updatedAt\":\"{{context.timestamp}}\"},\"$push\":{\"matchAnalysisHistory\":{\"id\":\"ai-job-application-match-analysis-{{context.entityId}}-{{context.timestamp}}\",\"payload\":{{value.matchAnalysis}},\"sourceRunId\":\"{{context.runId}}\",\"modelId\":\"{{context.entityJson.applicationContext.analysisRequest.modelId}}\",\"applicationId\":\"{{context.entityJson.applicationContext.applicationRecord.id}}\",\"canonicalApplicationKeySnapshot\":\"{{context.entityJson.applicationContext.applicationRecord.canonicalApplicationKey}}\",\"applicationUpdatedAtSnapshot\":\"{{context.entityJson.applicationContext.applicationRecord.updatedAt}}\",\"createdAt\":\"{{context.timestamp}}\"}}}"
        },
        "runtime": {
          "waitForInputs": true,
          "inputContracts": {
            "value": {
              "required": true
            },
            "context": {
              "required": true
            },
            "entityId": {
              "required": false
            }
          }
        }
      }
    },
    {
