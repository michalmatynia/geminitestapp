# Optional root-app handoff target for the standalone Database Engine workspace.
DATABASE_ENGINE_WEB_ORIGIN="http://localhost:3400"

# The Database Engine intentionally uses the root MongoDB source settings so it
# can manage geminitestapp, StudiQ, and CMS Builder backups/sync together.
APP_DB_PROVIDER="mongodb"
AUTH_DB_PROVIDER="mongodb"
MONGODB_ACTIVE_SOURCE_DEFAULT="local"
