{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@kangur/contracts": ["../../packages/kangur-contracts/src/index.ts"],
      "@kangur/contracts/*": ["../../packages/kangur-contracts/src/*"],
      "@kangur/core": ["../../packages/kangur-core/src/index.ts"],
      "@kangur/core/*": ["../../packages/kangur-core/src/*"],
      "@kangur/api-client": ["../../packages/kangur-api-client/src/index.ts"],
      "@kangur/api-client/*": ["../../packages/kangur-api-client/src/*"],
      "@kangur/platform": ["../../packages/kangur-platform/src/index.ts"],
      "@kangur/platform/*": ["../../packages/kangur-platform/src/*"],
      "@/features/*": ["../../src/features/*"],
      "@/shared/*": ["../../src/shared/*"],
      "@/server/*": ["../../src/server/*"],
      "@/i18n/*": ["../../src/i18n/*"],
      "@/app/*": ["../../src/app/*"],
      "@docs/*": ["../../docs/*"],
      "@/*": ["./src/*"]
    },
    "types": ["react", "react-dom"]
  },
  "include": [
    "next-env.d.ts",
    "../../src/global.d.ts",
    "../../src/shared/contracts/ambient.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "**/__tests__/**", "**/*.test.ts", "**/*.test.tsx"]
}
