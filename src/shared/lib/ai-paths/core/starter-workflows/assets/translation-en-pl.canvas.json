        "y": 120
      },
      "inputs": ["bundle", "context"],
      "outputs": ["prompt", "images"],
      "config": {
        "prompt": {
          "template": "Translate the PRODUCT DESCRIPTION from English to Polish.\nProduct name: \"{{title}}\"\nEnglish description: \"{{description_en}}\"\n\nRules:\n1. Return ONLY valid JSON.\n2. Output schema: {\"description_pl\":\"<translated description>\"}.\n3. Keep brand names, model names, SKUs, and measurements unchanged.\n4. Do not invent claims or details.\n5. If the description is already in Polish, return it unchanged.\n6. No markdown, no code fences, no explanations."
        }
      }
    },
    {
      "id": "node-model-desc-translate-en-pl",
      "type": "model",
      "title": "Model",
      "description": "Translate the description to Polish.",
      "position": {
        "x": 1240,
        "y": 120
      },
      "inputs": ["prompt", "images", "context"],
      "outputs": ["result", "jobId"],
      "config": {
        "model": {
          "temperature": 0.1,
          "maxTokens": 900,
          "vision": false,
          "waitForResult": true
        }
      }
    },
    {
      "id": "node-regex-desc-translate-en-pl",
      "type": "regex",
      "title": "Regex Description JSON",
      "description": "Extract translated description JSON payload.",
      "position": {
