{
  "compilerOptions": {
    "target": "esnext",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "noEmitOnError": true,
    "useUnknownInCatchVariables": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "declaration": false,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@docs/*": [
        "./docs/*"
      ],
      "@/__tests__/*": [
        "./__tests__/*"
      ],
      "pg": [
        "./src/shared/lib/db/pg-stub.ts"
      ],
      "gsap/ScrollTrigger": [
        "./node_modules/gsap/types/scroll-trigger.d.ts"
      ],
      "gsap/MotionPathPlugin": [
        "./node_modules/gsap/types/motion-path-plugin.d.ts"
      ],
      "gsap/Flip": [
        "./node_modules/gsap/types/flip.d.ts"
      ],
      "gsap/Draggable": [
        "./node_modules/gsap/types/draggable.d.ts"
      ],
      "gsap/CustomEase": [
        "./node_modules/gsap/types/custom-ease.d.ts"
      ],
      "gsap/Observer": [
        "./node_modules/gsap/types/observer.d.ts"
      ]
    },
    "types": [
      "vitest/globals",
      "react-error-boundary",
      "@tanstack/react-query-devtools",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "types/**/*.d.ts",
    ".next/types/**/*.ts",
    "src/global.d.ts",
    "src/shared/contracts/ambient.d.ts",
    ".next/dev/types/**/*.ts",
    ".next-dev/types/**/*.ts",
    ".next-dev/dev/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019ced73-cdd8-76c0-a92e-d669555b7a06/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019ced73-cdd8-76c0-a92e-d669555b7a06/dev/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf039-fd62-78f0-be2e-79666dce389f/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf039-fd62-78f0-be2e-79666dce389f/dev/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019ced73-cdd8-76c0-a92e-d669555b7a06-route-crawl/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019ced73-cdd8-76c0-a92e-d669555b7a06-route-crawl/dev/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf039-fd62-78f0-be2e-79666dce389f-route-crawl/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf039-fd62-78f0-be2e-79666dce389f-route-crawl/dev/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf114-5b87-75d0-8359-f61aefb3bc55/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf114-5b87-75d0-8359-f61aefb3bc55/dev/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf114-5b87-75d0-8359-f61aefb3bc55-route-crawl/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf114-5b87-75d0-8359-f61aefb3bc55-route-crawl/dev/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf259-a755-7f90-b793-077cb4d50ddf/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf259-a755-7f90-b793-077cb4d50ddf/dev/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf259-a755-7f90-b793-077cb4d50ddf-route-crawl/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf259-a755-7f90-b793-077cb4d50ddf-route-crawl/dev/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf4c5-ed16-7863-8bbf-e3641a9d9b36/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf4c5-ed16-7863-8bbf-e3641a9d9b36/dev/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf7c7-96e6-7c60-8268-9ad505dd0c53-route-crawl/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-019cf7c7-96e6-7c60-8268-9ad505dd0c53-route-crawl/dev/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-webpack-019cf7c7-96e6-7c60-8268-9ad505dd0c53-route-crawl/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-webpack-019cf7c7-96e6-7c60-8268-9ad505dd0c53-route-crawl/dev/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-webpack-019cf7c7-96e6-7c60-8268-9ad505dd0c53/types/**/*.ts",
    ".next-dev-playwright-broker-web-dev-webpack-019cf7c7-96e6-7c60-8268-9ad505dd0c53/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".next-dev",
    ".next-dev-*",
    "bazel-*",
    "bazel-bin",
    "bazel-out",
    "bazel-testlogs",
    "tmp",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
