{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "__tests__/**/*.ts",
    "__tests__/**/*.tsx",
    "__tests__/**/*.js",
    "__tests__/**/*.jsx",
    "src/**/__tests__/**/*.ts",
    "src/**/__tests__/**/*.tsx",
    "src/**/__tests__/**/*.js",
    "src/**/__tests__/**/*.jsx",
    "e2e/**/*.ts",
    "e2e/**/*.tsx",
    "e2e/**/*.js",
    "e2e/**/*.jsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".next-dev",
    ".next-dev-*",
    "tmp"
  ]
}
