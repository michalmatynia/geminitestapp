      "position": { "x": 24, "y": 240 },
      "inputs": [],
      "outputs": ["trigger", "triggerName"],
      "config": {
        "trigger": {
          "event": "8e7a7cb6-8973-4aa4-b2ee-b7c8e5b93e78",
