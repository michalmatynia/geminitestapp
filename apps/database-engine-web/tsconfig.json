{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "es2022"],
    "noEmit": true,
    "paths": {
      "@/components/*": ["src/components/*"],
      "@/features/database": ["src/features/database/public.ts"],
      "@/features/database/*": ["src/features/database/*"],
      "@/shared/*": ["../../src/shared/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.mjs",
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../src/global.d.ts",
    "../../src/types/**/*.d.ts",
    "../../vitest.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
