{
  "compilerOptions": {
    "target": "esnext",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "noEmitOnError": true,
    "useUnknownInCatchVariables": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "declaration": false,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@docs/*": [
        "./docs/*"
      ],
      "@/__tests__/*": [
        "./__tests__/*"
      ],
      "gsap/ScrollTrigger": [
        "./node_modules/gsap/types/scroll-trigger.d.ts"
      ],
      "gsap/MotionPathPlugin": [
        "./node_modules/gsap/types/motion-path-plugin.d.ts"
      ],
      "gsap/Flip": [
        "./node_modules/gsap/types/flip.d.ts"
      ],
      "gsap/Draggable": [
        "./node_modules/gsap/types/draggable.d.ts"
      ],
      "gsap/CustomEase": [
        "./node_modules/gsap/types/custom-ease.d.ts"
      ],
      "gsap/Observer": [
        "./node_modules/gsap/types/observer.d.ts"
      ]
    },
    "types": [
      "vitest/globals",
      "react-error-boundary",
      "@tanstack/react-query-devtools",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "types/**/*.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next-dev/types/**/*.ts",
    ".next-dev/dev/types/**/*.ts",
    "src/global.d.ts",
    "src/shared/contracts/ambient.d.ts",
    ".next-codex-build/types/**/*.ts",
    ".next-codex-build/dev/types/**/*.ts",
    ".next-dev-web-dev-*/types/**/*.d.ts",
    ".next-dev-web-dev-*/dev/types/**/*.d.ts",
    ".next-dev-web-dev-*/types/**/*.ts",
    ".next-dev-web-dev-*/dev/types/**/*.ts",
    ".next-dev-web-dev-route-crawl-isolated/types/**/*.ts",
    ".next-dev-web-dev-route-crawl-isolated/dev/types/**/*.ts",
    ".next-dev-web-dev-michalmatynia/types/**/*.ts",
    ".next-dev-web-dev-michalmatynia/dev/types/**/*.ts",
    ".next-dev-web-dev-route-crawl-isolated-2/types/**/*.ts",
    ".next-dev-web-dev-route-crawl-isolated-2/dev/types/**/*.ts",
    ".next-dev-web-dev-route-crawl-isolated-3/types/**/*.ts",
    ".next-dev-web-dev-route-crawl-isolated-3/dev/types/**/*.ts",
    ".next-dev-web-dev-smoke-final/types/**/*.ts",
    ".next-dev-web-dev-smoke-final/dev/types/**/*.ts",
    ".next-dev-web-dev-route-crawl-isolated-5/types/**/*.ts",
    ".next-dev-web-dev-route-crawl-isolated-5/dev/types/**/*.ts",
    ".next-dev-web-dev-smoke-final-check/types/**/*.ts",
    ".next-dev-web-dev-smoke-final-check/dev/types/**/*.ts",
    ".next-dev-web-dev-smoke-final-2/types/**/*.ts",
    ".next-dev-web-dev-smoke-final-2/dev/types/**/*.ts",
    ".next-dev-web-dev-smoke-final-3/types/**/*.ts",
    ".next-dev-web-dev-smoke-final-3/dev/types/**/*.ts",
    ".next-dev-web-dev-smoke-cms-pages-solo/types/**/*.ts",
    ".next-dev-web-dev-smoke-cms-pages-solo/dev/types/**/*.ts",
    ".next-dev-web-dev-smoke-final-4/types/**/*.ts",
    ".next-dev-web-dev-smoke-final-4/dev/types/**/*.ts",
    ".next-dev-web-dev-smoke-final-5/types/**/*.ts",
    ".next-dev-web-dev-smoke-final-5/dev/types/**/*.ts",
    ".next-dev-web-dev-smoke-final-6/types/**/*.ts",
    ".next-dev-web-dev-smoke-final-6/dev/types/**/*.ts",
    ".next-dev-brain-debug/types/**/*.ts",
    ".next-dev-brain-debug/dev/types/**/*.ts",
    ".next-dev-web-dev-smoke-final-7/types/**/*.ts",
    ".next-dev-web-dev-smoke-final-7/dev/types/**/*.ts",
    ".next-dev-web-dev-route-crawl-final-6/types/**/*.ts",
    ".next-dev-web-dev-route-crawl-final-6/dev/types/**/*.ts",
    ".next-dev-web-dev-webpack-michalmatynia/types/**/*.ts",
    ".next-dev-web-dev-webpack-michalmatynia/dev/types/**/*.ts",
    ".next-dev-web-dev-codex-kangur-navigation-full/types/**/*.ts",
    ".next-dev-web-dev-codex-kangur-navigation-full/dev/types/**/*.ts",
    ".next-dev-web-dev-michalmatynia-route-crawl/types/**/*.ts",
    ".next-dev-web-dev-michalmatynia-route-crawl/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".next-dev",
    "tmp",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
