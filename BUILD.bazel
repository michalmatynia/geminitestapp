sh_binary(
    name = "weekly_trend_index",
    srcs = ["tools/bazel/node_script.sh"],
    args = ["scripts/quality/generate-trend-index.mjs", "--ci", "--no-history"],
    data = [
        ":weekly_quality_inputs",
        ":node_modules",
        ":package_metadata",
    ],
)

sh_binary(
    name = "weekly_duration_budgets",
    srcs = ["tools/bazel/node_script.sh"],
    args = ["scripts/quality/recalibrate-weekly-duration-budgets.mjs", "--ci", "--no-history"],
    data = [
        ":weekly_quality_inputs",
        ":node_modules",
        ":package_metadata",
    ],
