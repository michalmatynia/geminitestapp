# ImageKit ID - get from your ImageKit dashboard
IMAGEKIT_ID="your_imagekit_id"

# OpenAI API Key - get from your OpenAI dashboard
OPENAI_API_KEY="your_openai_api_key"

# Database URL - this is the default for the project
DATABASE_URL="file:./prisma/dev.db"
INTEGRATION_ENCRYPTION_KEY=""

# Base.com (BaseLinker) API
BASE_API_URL="https://api.baselinker.com/connector.php"

# Allegro OAuth
ALLEGRO_AUTH_URL="https://allegro.pl/auth/oauth/authorize"
ALLEGRO_TOKEN_URL="https://allegro.pl/auth/oauth/token"

# Optional MongoDB setup for product data
# PRODUCT_DB_PROVIDER="mongodb"
# INTEGRATION_DB_PROVIDER="mongodb"
# MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/dbname"
# MONGODB_DB="app"

# Optional MongoDB connection pool tuning
# MONGODB_MAX_POOL_SIZE="20"
# MONGODB_MIN_POOL_SIZE="1"
# MONGODB_MAX_IDLE_TIME_MS="60000"
# MONGODB_SERVER_SELECTION_TIMEOUT_MS="5000"
# MONGODB_CONNECT_TIMEOUT_MS="5000"
# MONGODB_SOCKET_TIMEOUT_MS="120000"
# Set to "true" to log slow commands and command failures (adds minor overhead)
# MONGODB_MONITOR_COMMANDS="false"
# Slow-command threshold in ms — only used when MONGODB_MONITOR_COMMANDS=true (default 3000)
# MONGODB_SLOW_COMMAND_MS="3000"

# Optional client telemetry controls
# NEXT_PUBLIC_ENABLE_PAGE_ANALYTICS="true"
# NEXT_PUBLIC_ENABLE_ADMIN_PAGE_ANALYTICS="true"
# NEXT_PUBLIC_ENABLE_PAGE_ANALYTICS_IN_DEV="true"
# NEXT_PUBLIC_ENABLE_QUERY_TELEMETRY="true"
# NEXT_PUBLIC_ENABLE_QUERY_TELEMETRY_IN_DEV="true"

# Optional analytics ingestion mode
# Set to "true" to wait for DB write before responding from /api/analytics/events
# ANALYTICS_EVENTS_BLOCKING_INGESTION="false"
# Set to "true" to wait for log persistence before responding from /api/query-telemetry
# QUERY_TELEMETRY_BLOCKING_INGESTION="false"
# Set to "true" to include raw query keys in telemetry payloads (sensitive in production)
# QUERY_TELEMETRY_STORE_RAW_KEYS="false"

# Optional OpenTelemetry server-side instrumentation
# Set to "true" to force-enable OTel even if endpoints are not explicitly set
# OTEL_ENABLED="false"
# OTEL_SERVICE_NAME="geminitestapp"
# OTEL_SERVICE_VERSION="0.1.0"
# OTLP base endpoint (signal paths are auto-derived if needed)
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
# Signal-specific endpoints (override base endpoint when set)
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT="http://localhost:4318/v1/traces"
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT="http://localhost:4318/v1/logs"
# Optional comma-separated headers: key=value,key2=value2
# OTEL_EXPORTER_OTLP_HEADERS="Authorization=Bearer your-token"
# Optional trace sampling strategy configuration
# OTEL_TRACES_SAMPLER="parentbased_traceidratio"
# OTEL_TRACES_SAMPLER_ARG="0.2"

# Optional centralized system-log forwarding webhook
# CENTRAL_LOG_WEBHOOK_URL="https://logs.example.com/ingest"

# Optional critical error outbound notifications
# CRITICAL_ERROR_NOTIFICATIONS_ENABLED="false"
# CRITICAL_ERROR_WEBHOOK_URL="https://hooks.example.com/critical-errors"
# CRITICAL_ERROR_MIN_LEVEL="error"
# CRITICAL_ERROR_THROTTLE_SECONDS="120"

# Optional system-log alert worker switch
# SYSTEM_LOG_ALERTS_ENABLED="true"

# Optional Image Studio crop hardening flags
# IMAGE_STUDIO_CROP_PIPELINE_VERSION="v2"
# IMAGE_STUDIO_CROP_SERVER_AUTHORITATIVE="true"

# Optional Image Studio center hardening flags
# IMAGE_STUDIO_CENTER_PIPELINE_VERSION="v2"
# IMAGE_STUDIO_CENTER_SERVER_AUTHORITATIVE="true"
# IMAGE_STUDIO_CENTER_DEDUPE_BY_FINGERPRINT="false"

# Optional Image Studio upscale hardening flags
# IMAGE_STUDIO_UPSCALE_PIPELINE_VERSION="v2"
# IMAGE_STUDIO_UPSCALE_SERVER_AUTHORITATIVE="true"

# Optional AI Paths asset base URL — set to your app's public base URL so that AI-Paths
# model nodes can fetch self-hosted product images when they are stored as absolute URLs
# pointing to your own server.  Relative image URLs (/uploads/…) are always allowed.
# In development:  AI_PATHS_ASSET_BASE_URL="http://localhost:3000"
# In production:   AI_PATHS_ASSET_BASE_URL="https://myapp.example.com"
# AI_PATHS_ASSET_BASE_URL=""

# Optional AI Paths reliability/performance controls
# AI_PATHS_STALE_RUNNING_MAX_AGE_MS="1800000"
# AI_PATHS_STALE_RUNNING_CLEANUP_INTERVAL_MS="120000"
# AI_PATHS_HEALTH_CRITICAL_GRACE_MS="900000"
# AI_PATHS_RUNTIME_STATE_FLUSH_INTERVAL_MS="2000"
# AI_PATHS_LOG_NODE_START_EVENTS="false"
# AI_PATHS_STREAM_EVENT_LIMIT="200"
# AI_PATHS_STREAM_NODE_LIMIT="200"
# AI_PATHS_ACTION_RATE_LIMIT_WINDOW_SECONDS="60"
# AI_PATHS_ACTION_RATE_LIMIT_MAX="120"
# Server-side settings cache TTL (ms) — longer = fewer cold MongoDB fetches (default 60000)
# AI_PATHS_SERVER_SETTINGS_CACHE_TTL_MS="60000"
# Analytics query timeout (ms) — increase if Redis is slow (default 5000)
# AI_PATHS_RUNTIME_SUMMARY_TIMEOUT_MS="5000"
# Trace analytics run sample limit — lower = faster analytics queries (default 100)
# AI_PATHS_RUNTIME_TRACE_RUN_SAMPLE_LIMIT="100"
# Runs list response cache TTL (ms) — reduces repeated MongoDB scans on UI polling (default 3000)
# AI_PATHS_RUNS_LIST_CACHE_TTL_MS="3000"
# DB action request timeout for server-side AI Paths runtime writes (default 30000)
# AI_PATHS_DB_ACTION_TIMEOUT_MS="30000"

# Optional AI Paths queue worker controls
# BullMQ worker concurrency — number of runs processed in parallel (default 3)
# AI_PATHS_RUN_CONCURRENCY="3"
# Per-job wall-clock timeout in ms; 0 = disabled (default 600000 = 10 min)
# AI_PATHS_JOB_TIMEOUT_MS="600000"
# Maximum run retry attempts before dead-lettering (default 3)
# AI_PATHS_RUN_MAX_ATTEMPTS="3"
# Base backoff delay in ms between retries (default 5000)
# AI_PATHS_RUN_BACKOFF_MS="5000"
# Maximum backoff cap in ms (default 60000)
# AI_PATHS_RUN_BACKOFF_MAX_MS="60000"
# Set to "true" to enable verbose queue debug logging
# AI_PATHS_QUEUE_DEBUG="false"

# Optional Base.com importer reliability controls
# BASE_IMPORT_MAX_ATTEMPTS="3"
# BASE_IMPORT_RETRY_BASE_DELAY_MS="2000"
# BASE_IMPORT_RETRY_MAX_DELAY_MS="60000"
# BASE_IMPORT_LEASE_MS="60000"
# BASE_IMPORT_HEARTBEAT_EVERY_ITEMS="10"

# Optional Prompt Exploder runtime rollout controls
# NEXT_PUBLIC_PROMPT_VALIDATION_ORCHESTRATOR_V2="true"
# NEXT_PUBLIC_PROMPT_VALIDATION_ORCHESTRATOR_CANARY_PERCENT="100"
# NEXT_PUBLIC_PROMPT_VALIDATION_STRICT_STACK_MODE="false"

# Optional Case Resolver document editor rollout control
# NEXT_PUBLIC_CASE_RESOLVER_MULTIFORMAT_EDITOR="true"

# Optional external file storage (FastComet)
# FILE_STORAGE_SOURCE="local" # or "fastcomet"
# FASTCOMET_STORAGE_BASE_URL="https://files.example.com"
# FASTCOMET_STORAGE_UPLOAD_URL="https://files.example.com/api/uploads"
# FASTCOMET_STORAGE_DELETE_URL="https://files.example.com/api/uploads/delete"
# FASTCOMET_STORAGE_AUTH_TOKEN=""
# FASTCOMET_STORAGE_KEEP_LOCAL_COPY="true"
# FASTCOMET_STORAGE_TIMEOUT_MS="20000"
