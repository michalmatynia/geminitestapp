sh_binary(
    name = "security_smoke",
    srcs = ["tools/bazel/node_script.sh"],
    args = ["scripts/testing/run-security-smoke-tests.mjs", "--strict", "--ci"],
    data = [
        ":testing_gate_inputs",
        ":node_modules",
