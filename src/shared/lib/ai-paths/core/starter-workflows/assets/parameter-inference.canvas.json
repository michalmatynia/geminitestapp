            "preset": "by_id",
            "field": "_id",
            "idType": "string",
            "queryTemplate": "{\n  \"id\": \"{{entityId}}\",\n  \"$or\": [\n    { \"parameters\": { \"$exists\": false } },\n    { \"parameters\": { \"$size\": 0 } }\n  ]\n}",
