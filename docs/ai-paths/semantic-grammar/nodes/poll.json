{
  "specVersion": "ai-paths.semantic-grammar.v1",
  "nodeType": "poll",
  "title": "Poll Job",
  "purpose": "Poll an AI job or database query until it completes.",
  "inputs": [
    "jobId",
    "query",
    "value",
    "entityId",
    "productId",
    "bundle"
  ],
  "outputs": [
    "result",
    "status",
    "jobId",
    "bundle"
  ],
  "configFields": [
    {
      "path": "poll.mode",
      "description": "job = poll AI job status; database = poll database query.",
      "defaultValue": "job"
    },
    {
      "path": "poll.intervalMs",
      "description": "Wait time between polling attempts (ms).",
      "defaultValue": "1000"
    },
    {
      "path": "poll.maxAttempts",
      "description": "Maximum polling attempts before failing.",
      "defaultValue": "40"
    },
    {
      "path": "poll.dbQuery",
      "description": "Database query definition used when mode is database (provider/collection/preset/queryTemplate/etc)."
    },
    {
      "path": "poll.dbQuery.provider",
      "description": "Database provider (mongodb|prisma).",
      "defaultValue": "mongodb"
    },
    {
      "path": "poll.dbQuery.collection",
      "description": "Collection to query (example: products).",
      "defaultValue": "\"products\""
    },
    {
      "path": "poll.dbQuery.mode",
      "description": "preset uses a predefined query; custom uses queryTemplate.",
      "defaultValue": "preset"
    },
    {
      "path": "poll.dbQuery.preset",
      "description": "Preset query shape (by_id/by_productId/by_entityId/by_field).",
      "defaultValue": "by_id"
    },
    {
      "path": "poll.dbQuery.field",
      "description": "Field used by preset queries (example: _id, productId).",
      "defaultValue": "\"_id\""
    },
    {
      "path": "poll.dbQuery.idType",
      "description": "How to treat IDs: string vs objectId.",
      "defaultValue": "string"
    },
    {
      "path": "poll.dbQuery.queryTemplate",
      "description": "JSON query template (string) with {{placeholders}}.",
      "defaultValue": "\"{...}\""
    },
    {
      "path": "poll.dbQuery.limit",
      "description": "Limit for multi-result queries.",
      "defaultValue": "20"
    },
    {
      "path": "poll.dbQuery.sort",
      "description": "Sort JSON (string).",
      "defaultValue": "\"\""
    },
    {
      "path": "poll.dbQuery.projection",
      "description": "Projection JSON (string).",
      "defaultValue": "\"\""
    },
    {
      "path": "poll.dbQuery.single",
      "description": "If true, treat result as a single document.",
      "defaultValue": "false"
    },
    {
      "path": "poll.successPath",
      "description": "Optional JSON path evaluated against the polled result to determine completion."
    },
    {
      "path": "poll.successOperator",
      "description": "truthy/equals/contains/notEquals used with successPath.",
      "defaultValue": "truthy"
    },
    {
      "path": "poll.successValue",
      "description": "String value used by equals/contains/notEquals."
    },
    {
      "path": "poll.resultPath",
      "description": "Optional JSON path to extract the final result payload to emit."
    },
    {
      "path": "runtime.cache.mode",
      "description": "Node output caching. auto = reuse when safe, force = always reuse, disabled = recompute each run.",
      "defaultValue": "auto"
    },
    {
      "path": "runtime.waitForInputs",
      "description": "If true, wait until all connected input ports have values before executing the node.",
      "defaultValue": "false"
    }
  ],
  "notes": [],
  "semanticNodeExample": {
    "id": "node_poll",
    "type": "poll",
    "title": "Poll Job",
    "description": "Poll an AI job or database query until it completes.",
    "position": {
      "x": 100,
      "y": 100
    },
    "inputs": [
      "jobId",
      "query",
      "value",
      "entityId",
      "productId",
      "bundle"
    ],
    "outputs": [
      "result",
      "status",
      "jobId",
      "bundle"
    ],
    "data": {},
    "connections": {
      "incoming": [],
      "outgoing": []
    }
  }
}
